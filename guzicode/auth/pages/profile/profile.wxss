@import "../../../app.wxss";

.auth-shell {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.auth-status {
  position: relative;
  height: calc(172rpx + env(safe-area-inset-top));
}

.auth-content {
  animation: softFadeIn 0.42s ease-out both;
  position: relative;
}

/* 装饰星星和圆点 */
.decor {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.decor-star {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  background: rgba(255, 255, 255, 0.95);
  transform: rotate(45deg);
}

.decor-dot {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(255, 215, 230, 0.55);
}

.decor-dot--purple {
  background: rgba(201, 194, 255, 0.55);
}

.page-back {
  position: absolute;
  left: 32rpx;
  top: calc(96rpx + env(safe-area-inset-top));
  z-index: 4;
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(217, 236, 248, 0.9);
  box-shadow: 0 12rpx 24rpx rgba(45, 76, 120, 0.08);
}

.page-back::before {
  content: "";
  position: absolute;
  left: 25rpx;
  top: 25rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #557087;
  border-bottom: 4rpx solid #557087;
  transform: rotate(45deg);
}

.brand-block {
  padding: 40rpx 0 48rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.brand-mark {
  width: 148rpx;
  height: 148rpx;
  margin: 0 auto 28rpx;
  border-radius: 48rpx;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.86), rgba(176, 221, 250, 0.8));
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 20rpx 52rpx rgba(176, 221, 250, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #3b4e67;
  font-size: 56rpx;
}

.brand-title {
  color: #24364a;
  font-size: 44rpx;
  line-height: 1.18;
  font-weight: 900;
}

.brand-subtitle {
  margin-top: 16rpx;
  color: #6b7f95;
  font-size: 28rpx;
  line-height: 1.6;
}

.form-card {
  padding: 44rpx 40rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 24rpx 60rpx rgba(116, 148, 181, 0.12);
  position: relative;
  z-index: 1;
}

.avatar-card {
  margin: 4rpx 0 36rpx;
  text-align: center;
}

.avatar-box {
  width: 232rpx;
  height: 232rpx;
  margin: 0 auto 18rpx;
  border-radius: 50%;
  border: 4rpx dashed rgba(121, 167, 199, 0.56);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(234, 247, 255, 0.9));
  box-shadow: inset 0 0 0 20rpx rgba(255, 255, 255, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-icon {
  color: #3b4e67;
  font-size: 76rpx;
}

.avatar-tip {
  color: #6b7f95;
  font-size: 28rpx;
  line-height: 1.6;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  margin-bottom: 14rpx;
  color: #557087;
  font-size: 28rpx;
  font-weight: 700;
}

.form-field {
  height: 96rpx;
  padding: 0 30rpx;
  border-radius: 28rpx;
  border: 2rpx solid #d9ecf8;
  background: rgba(255, 255, 255, 0.94);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.form-field--error {
  border-color: #ffb7c8;
}

.field-input {
  flex: 1;
  height: 100%;
  color: #24364a;
  font-size: 32rpx;
  line-height: 96rpx;
}

.field-placeholder {
  color: #a0aec0;
}

.error-text {
  margin: 12rpx 8rpx 0;
  color: #ff7f96;
  font-size: 24rpx;
  line-height: 1.5;
}

.submit-btn {
  width: 100%;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  position: static;
  height: 96rpx;
  line-height: 96rpx;
  border: 0;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #c0e7ff 0%, #b0ddfa 100%);
  color: #24435a;
  font-size: 32rpx;
  font-weight: 900;
  box-shadow: 0 24rpx 42rpx rgba(176, 221, 250, 0.35);
}

.submit-btn::after {
  border: 0;
}

.submit-btn[disabled] {
  background: #ddeaf2;
  color: #94a3b8;
  box-shadow: none;
}

@keyframes softFadeIn {
  0% {
    opacity: 0;
    transform: translateY(28rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}
