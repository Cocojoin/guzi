@import "../../../../../app.wxss";

page {
  background: linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.management-shell {
  min-height: 100vh;
  background: linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.management-page {
  padding-top: calc(24rpx + env(safe-area-inset-top));
}

.search-box,
.product-card {
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 42rpx rgba(116, 148, 181, 0.12);
}

.search-box {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #334155;
}

.search-placeholder {
  color: #a0aec0;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #edf2fa;
  color: #7d8ca3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tips-text {
  margin: 18rpx 4rpx 22rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b97ad;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.product-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
}

.product-card--disabled {
  opacity: 0.72;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  border: 3rpx solid #ccd6e6;
  background: #ffffff;
  box-sizing: border-box;
  flex-shrink: 0;
}

.checkbox--checked {
  border-color: #7aaef0;
  background: linear-gradient(180deg, #c0e7ff 0%, #9fc8f3 100%);
  position: relative;
}

.checkbox--checked::after {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 6rpx;
  width: 12rpx;
  height: 20rpx;
  border-right: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(40deg);
}

.checkbox--disabled {
  background: #edf2f8;
}

.group-cover {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #efe9ff, #ddd2fb);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.group-cover--unassigned {
  background: linear-gradient(135deg, #eef2f8, #dde5f1);
}

.group-cover-text {
  font-size: 40rpx;
  font-weight: 700;
  color: rgba(88, 104, 131, 0.72);
}

.product-main {
  flex: 1;
  min-width: 0;
}

.product-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #334155;
  line-height: 1.45;
}

.product-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8b97ad;
}

.product-tags {
  margin-top: 12rpx;
}

.tag {
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
}

.tag--current {
  color: #377ba9;
  background: #dcefff;
}

.tag--muted {
  color: #98a4b8;
  background: #edf2f8;
}

.empty-state {
  padding: 56rpx 32rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #334155;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8b97ad;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(248, 251, 255, 0.96);
}

.action-btn {
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #c0e7ff 0%, #a7cff3 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: 0;
}

.action-btn[disabled] {
  background: #ddeaf2;
  color: #94a3b8;
}
