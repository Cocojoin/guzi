@import "../../../../app.wxss";

.detail-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.detail-page {
  min-height: 100vh;
  padding: 48rpx 32rpx 56rpx;
  box-sizing: border-box;
}

.statusbar-spacer {
  height: calc(120rpx + env(safe-area-inset-top));
}

.page-topbar {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.operation-log-header {
  position: relative;
  justify-content: center;
  padding-right: 0;
  min-height: 72rpx;
}

.operation-log-header .back-button {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #223650;
  text-align: center;
}

.retention-card {
  margin-bottom: 20rpx;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.retention-copy {
  flex: 1;
  min-width: 0;
}

.retention-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2b3f59;
}

.retention-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8b9ab0;
}

.retention-actions {
  display: flex;
  gap: 12rpx;
}

.retention-btn {
  min-width: 92rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(208, 216, 255, 0.96), rgba(226, 232, 255, 0.96));
  color: #5560d7;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.retention-btn--ghost {
  background: rgba(246, 248, 252, 0.96);
  color: #72859d;
}

.search-box {
  padding: 0 24rpx;
  height: 84rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  display: flex;
  align-items: center;
}

.search-input {
  width: 100%;
  font-size: 32rpx;
  color: #334155;
  line-height: 84rpx;
}

.search-placeholder {
  color: #b0bacc;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.filter-chip {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 2rpx solid rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  color: #667c98;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-chip--active {
  background: linear-gradient(180deg, rgba(208, 216, 255, 0.96), rgba(226, 232, 255, 0.96));
  color: #5560d7;
}

.filter-chip--danger {
  background: rgba(255, 236, 241, 0.92);
  color: #df5e7d;
  border-color: rgba(255, 198, 210, 0.92);
}

.log-scroll {
  height: calc(100vh - 330rpx - env(safe-area-inset-top));
  margin-top: 24rpx;
}

.list-refresh-tip {
  padding: 10rpx 0 4rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  font-weight: 600;
}

.log-card {
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 36rpx rgba(127, 154, 190, 0.09);
}

.log-card--danger {
  background: rgba(255, 242, 245, 0.9);
  border-color: rgba(255, 196, 208, 0.92);
}

.log-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.log-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.log-alert {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #f0627e;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.log-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2b3f59;
}

.log-status {
  min-width: 84rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.log-status--success {
  background: rgba(123, 207, 166, 0.18);
  color: #3f9f72;
}

.log-status--danger {
  background: rgba(248, 119, 145, 0.14);
  color: #e85d79;
}

.log-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 14rpx;
}

.log-label {
  font-size: 28rpx;
  color: #99a5b5;
}

.log-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #566b89;
  line-height: 1.5;
}

.log-note {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(242, 245, 250, 0.92);
  font-size: 24rpx;
  line-height: 1.6;
  color: #6f83a1;
}

.log-note--danger {
  background: rgba(255, 227, 233, 0.78);
  color: #d85775;
}

.state-card {
  width: 100%;
  max-width: 320rpx;
  margin: 240rpx auto 0;
  text-align: center;
}

.state-card--error {
  margin-top: 220rpx;
}

.state-emoji {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.76);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
}

.state-title {
  margin-top: 28rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #2b3f59;
}

.state-copy {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #a0acc0;
}

.state-btn {
  width: 220rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 34rpx auto 0;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(191, 203, 255, 0.96);
  color: #5b67d6;
  font-size: 32rpx;
  font-weight: 700;
}
