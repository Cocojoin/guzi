@import "../../../../app.wxss";

.shop-page-shell {
  min-height: 100vh;
}

.shop-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(248, 251, 255, 0.96);
  backdrop-filter: blur(18rpx);
}

.shop-nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  padding: 0 32rpx 6rpx;
  gap: 16rpx;
}

.shop-nav-status {
  width: 100%;
}

.shop-back {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
  flex-shrink: 0;
}

.shop-back::before {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 24rpx;
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #1f2937;
  border-bottom: 4rpx solid #1f2937;
  transform: rotate(45deg);
}

.shop-nav-main {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: calc(100% - 320rpx);
  max-width: 420rpx;
  min-width: 0;
}

.shop-nav-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-nav-action {
  flex-shrink: 0;
  color: #526887;
  font-size: 30rpx;
  font-weight: 700;
}

.shop-page {
  padding-left: 28rpx;
  padding-right: 36rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.shop-top-gap {
  height: 28rpx;
}

.section-title {
  margin: 0 4rpx 18rpx;
  color: #526887;
  font-size: 36rpx;
  font-weight: 800;
}

.section-title--spaced {
  margin-top: 52rpx;
}

.section-row {
  margin-top: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.channel-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.channel-card,
.service-card {
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(255, 255, 255, 0.94);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 36rpx rgba(116, 148, 181, 0.11);
}

.channel-card {
  padding: 28rpx 24rpx;
  margin-right: 4rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.channel-card--disabled {
  opacity: 0.72;
}

.channel-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.preview-platform {
  width: 74rpx;
  height: 74rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.channel-meta {
  flex: 1;
  min-width: 0;
}

.channel-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.channel-title {
  min-width: 0;
  color: #31425e;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.25;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.channel-subtitle {
  margin-top: 10rpx;
  color: #95a4ba;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
}

.disabled-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef2f8;
  color: #a5b1c2;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.channel-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  padding-right: 2rpx;
}

.edit-btn,
.add-btn {
  margin: 0;
  min-width: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.edit-btn::after,
.add-btn::after {
  border: 0;
}

.edit-btn {
  height: 52rpx;
  width: 144rpx;
  min-width: 144rpx;
  max-width: 144rpx;
  padding: 0;
  color: #6d74d8;
  background: rgba(244, 245, 255, 0.98);
  border: 2rpx solid rgba(204, 208, 255, 0.9);
  font-size: 26rpx;
  flex: 0 0 144rpx;
}

.add-btn {
  width: 188rpx;
  min-width: 188rpx;
  max-width: 188rpx;
  flex: 0 0 188rpx;
  height: 58rpx;
  padding: 0;
  color: #ffffff;
  background: linear-gradient(180deg, #b7dcff 0%, #a5cdf8 100%);
  box-shadow: 0 12rpx 24rpx rgba(165, 205, 248, 0.28);
  margin-right: 12rpx;
  font-size: 28rpx;
}

.sort-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 4rpx;
  flex-shrink: 0;
}

.sort-btn {
  min-width: 76rpx;
  text-align: center;
  padding: 10rpx 14rpx;
  border-radius: 18rpx;
  background: #f1f6fd;
  color: #637590;
  font-size: 24rpx;
  font-weight: 700;
}

.service-card {
  margin-right: 4rpx;
  padding: 30rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.service-main {
  flex: 1;
  min-width: 0;
}

.service-title {
  color: #31425e;
  font-size: 32rpx;
  font-weight: 800;
}

.service-desc {
  margin-top: 10rpx;
  color: #99a8bc;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 700;
}

.shop-footnote {
  margin-top: 40rpx;
  color: #a7b3c5;
  font-size: 24rpx;
  line-height: 1.75;
  text-align: center;
}

.toggle-switch {
  position: relative;
  width: 92rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: rgba(227, 233, 246, 0.95);
  box-shadow: inset 0 0 0 2rpx rgba(219, 226, 241, 0.95);
  transition: background 0.2s ease;
  flex-shrink: 0;
}

.toggle-switch--on {
  background: linear-gradient(180deg, #b7dcff 0%, #a5cdf8 100%);
  box-shadow: inset 0 0 0 2rpx rgba(171, 209, 247, 0.95);
}

.toggle-switch-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(111, 135, 171, 0.18);
  transition: transform 0.2s ease;
}

.toggle-switch--on .toggle-switch-knob {
  transform: translateX(40rpx);
}

.shop-platform--taobao {
  background: linear-gradient(180deg, rgba(255, 235, 214, 0.98), rgba(255, 223, 199, 0.98));
  color: #ec7a2a;
}

.shop-platform--pdd {
  background: linear-gradient(180deg, rgba(255, 225, 224, 0.98), rgba(255, 210, 208, 0.98));
  color: #f14545;
}

.shop-platform--xhs {
  background: linear-gradient(180deg, rgba(255, 228, 235, 0.98), rgba(255, 216, 226, 0.98));
  color: #ef526e;
}

.shop-platform--xianyu {
  background: linear-gradient(180deg, rgba(250, 239, 219, 0.98), rgba(244, 230, 200, 0.98));
  color: #e1a244;
}

.shop-platform--weidian {
  background: linear-gradient(180deg, rgba(255, 231, 223, 0.98), rgba(255, 219, 207, 0.98));
  color: #ea6f3d;
}

.shop-platform--douyin {
  background: linear-gradient(180deg, rgba(233, 234, 240, 0.98), rgba(219, 220, 228, 0.98));
  color: #505562;
}

.shop-platform--wechat {
  background: linear-gradient(180deg, rgba(220, 244, 227, 0.98), rgba(206, 236, 215, 0.98));
  color: #30a76c;
}

.shop-platform--official {
  background: linear-gradient(180deg, rgba(225, 228, 255, 0.98), rgba(213, 218, 252, 0.98));
  color: #6770d8;
}
