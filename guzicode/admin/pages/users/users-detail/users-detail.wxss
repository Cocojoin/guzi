/* 用户详情页样式 */

page {
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
  color: #334155;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

/* 页面容器 */
.user-detail-page {
  min-height: 100vh;
  padding-top: 32rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

/* 状态栏占位 */
.statusbar-spacer {
  height: calc(104rpx + env(safe-area-inset-top));
}

/* 顶部导航栏 */
.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-right: calc(220rpx + env(safe-area-inset-right));
  padding-top: env(safe-area-inset-top);
  background: rgba(252, 254, 255, 0.92);
  z-index: 100;
  box-sizing: border-box;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(116, 148, 181, 0.15);
}

.back-icon {
  font-size: 48rpx;
  color: #334155;
  font-weight: bold;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2b3551;
}

.header-placeholder {
  width: 64rpx;
}

/* 内容区域 */
.content-scroll {
  padding: 0 32rpx 56rpx;
}

/* Header卡片：用户信息 */
.hero-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 245, 248, 0.95) 0%, rgba(255, 235, 242, 0.85) 100%);
  border: 2rpx solid rgba(255, 225, 235, 0.6);
  box-shadow: 0 18rpx 42rpx rgba(116, 148, 181, 0.12);
}

/* 头像 */
.avatar-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #8CCBFF, #B7A8FF 52%, #FFB8D1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  font-weight: 700;
  color: #ffffff;
  box-shadow: inset 0 0 0 4rpx rgba(255, 255, 255, 0.5);
}

/* 用户信息 */
.user-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #2b3551;
  line-height: 1.3;
}

.role-tag {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(176, 221, 250, 0.36);
  font-size: 24rpx;
  font-weight: 600;
  color: #4374a5;
  flex-shrink: 0;
}

.account-line,
.contact-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.account-line {
  margin-bottom: 4rpx;
}

.contact-line {
  margin-bottom: 0;
}

.label {
  color: #7085a0;
  flex-shrink: 0;
}

.value {
  color: #2b3551;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 统计区 */
.stats-row {
  display: flex;
  gap: 12rpx;
  margin-top: 28rpx;
}

.stat-card {
  flex: 1;
  padding: 28rpx 16rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(217, 236, 248, 0.95);
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(116, 148, 181, 0.12);
}

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #2a3855;
  line-height: 1.2;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7589a1;
}

/* 用户信息卡片 */
.info-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(116, 148, 181, 0.12);
}

.card-header {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  margin-bottom: 28rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2f3a56;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(217, 236, 248, 0.82);
}

.info-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 28rpx;
  color: #637990;
}

.item-value-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.item-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2b3b54;
}

.edit-icon {
  font-size: 24rpx;
  opacity: 0.6;
}

/* 寄售权限卡片 */
.permission-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(116, 148, 181, 0.12);
}

.permission-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.switch-wrap {
  flex-shrink: 0;
}

.custom-switch {
  transform: scale(0.9, 0.8);
}

/* 重置密码按钮 */
.reset-btn {
  width: 100%;
  height: 96rpx;
  margin-top: 36rpx;
  border-radius: 28rpx;
  border: none;
  background: linear-gradient(180deg, #ffe8ed 0%, #ffd4de 100%);
  font-size: 32rpx;
  font-weight: 600;
  color: #d55e79;
  line-height: 96rpx;
  text-align: center;
}

.reset-btn::after {
  border: none;
}

/* 编辑弹窗 */
.edit-popup {
  position: fixed;
  inset: 0;
  z-index: 200;
}

.popup-mask {
  position: absolute;
  inset: 0;
  background: rgba(38, 50, 77, 0.28);
}

.popup-content {
  position: absolute;
  left: 50%;
  right: auto;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 480rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 42rpx rgba(116, 148, 181, 0.12);
  overflow: hidden;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
}

.popup-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2b3551;
}

.popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #99a6b8;
}

.popup-body {
  padding: 0 32rpx;
}

.popup-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 26rpx;
  border: 2rpx solid rgba(198, 222, 241, 0.95);
  background: rgba(255, 255, 255, 0.92);
  font-size: 32rpx;
  color: #334155;
  box-sizing: border-box;
}

.error-msg {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #ff7f96;
}

.popup-footer {
  display: flex;
  gap: 20rpx;
  padding: 32rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-cancel {
  background: rgba(242, 248, 255, 0.95);
  color: #6e82a0;
}

.btn-confirm {
  background: linear-gradient(180deg, #d6ebff 0%, #bce0fb 100%);
  color: #28445f;
}

/* 确认弹窗 */
.confirm-popup {
  position: fixed;
  inset: 0;
  z-index: 200;
}

.confirm-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #6f839c;
}

.popup-content--small {
  max-width: 560rpx;
  margin: 0 auto;
}
