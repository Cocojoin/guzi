@import "../../../app.wxss";

.management-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.management-shell--detail {
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.management-page {
  min-height: 100vh;
  padding: 32rpx 24rpx 196rpx;
  box-sizing: border-box;
}

.management-page--list-offset {
  padding-top: 32rpx;
}

.management-page--with-bar {
  padding-bottom: 300rpx;
}

.error-banner {
  margin: 10rpx 4rpx 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 163, 182, 0.8);
  background: rgba(255, 245, 248, 0.92);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.error-banner-text {
  flex: 1;
  font-size: 24rpx;
  color: #c4546f;
  line-height: 1.4;
}

.error-banner-retry {
  flex-shrink: 0;
  min-width: 84rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 163, 182, 0.9);
  color: #c4546f;
  font-size: 24rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.management-header {
  position: relative;
  margin-bottom: 28rpx;
  display: block !important;
  width: 100%;
  box-sizing: border-box;
  padding-right: 0;
}

.header-title {
  text-align: center;
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a1a;
  line-height: 1.2;
  margin-bottom: 32rpx;
}

.header-actions {
  display: flex;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: -2rpx;
  width: 100%;
  box-sizing: border-box;
  flex: none;
}

.header-search {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.header-search-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #24364a;
  padding-left: 8rpx;
  box-sizing: border-box;
}

.header-search-placeholder {
  color: #9aa9bd;
  font-weight: 500;
}

.header-search-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(242, 250, 255, 0.9);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  color: #6c8aa3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
  flex: 0 0 40rpx;
  position: relative;
}

.header-search-clear::before,
.header-search-clear::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #6c8aa3;
  transform-origin: center;
}

.header-search-clear::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.header-search-clear::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.header-search-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(192, 231, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 4rpx;
}

.header-search-icon {
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid #79a7c7;
  border-radius: 50%;
  position: relative;
  box-sizing: border-box;
  flex: 0 0 22rpx;
}

.header-search-icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -6rpx;
  width: 10rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #79a7c7;
  transform: rotate(45deg);
}

.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  align-items: center;
  flex-wrap: nowrap;
  position: relative;
  z-index: 20;
}

.filter-anchor {
  position: relative;
  flex: 0 1 auto;
  min-width: 0;
}

.filter-chip {
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  color: #6f84a0;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  display: inline-flex;
  align-items: center;
}

.filter-chip--role {
  min-width: 0;
}

.filter-chip--inactive {
  min-width: 0;
}

.batch-btn {
  margin-left: auto;
  height: 48rpx;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: #6c8aa3;
  font-size: 28rpx;
  font-weight: 600;
  flex: 0 0 auto;
  white-space: nowrap;
}

.role-dropdown {
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  box-shadow: 0 12rpx 28rpx rgba(116, 148, 181, 0.12);
  padding: 8rpx;
}

.role-dropdown--inline {
  position: absolute;
  left: 0;
  top: calc(100% + 12rpx);
  width: 220rpx;
  z-index: 50;
}

.role-dropdown--inactive {
  width: 240rpx;
}

.role-option {
  height: 64rpx;
  border-radius: 20rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #647f98;
  font-size: 28rpx;
}

.role-option--active {
  background: rgba(176, 221, 250, 0.34);
  color: #27435f;
}

.list-card {
  align-items: flex-start;
}

.list-card--batch {
  position: relative;
  padding-left: 48rpx;
  align-items: center;
}

.list-card--batch .select-col {
  left: 0;
}

.list-card--selected {
  border-color: rgba(176, 221, 250, 1);
  box-shadow:
    0 24rpx 52rpx rgba(45, 76, 120, 0.12),
    inset 0 0 0 4rpx rgba(176, 221, 250, 0.36);
}

.list-card--disabled {
  opacity: 0.56;
}

.user-list {
  margin-top: 32rpx;
}

.list-refresh-tip {
  margin-top: 18rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  font-weight: 600;
}

.list-card--consignment {
  background: rgba(255, 255, 255, 0.9);
}

.list-card--normal {
  background: rgba(245, 249, 255, 0.92);
}

.list-subtitle {
  margin-top: 4rpx;
  line-height: 1.4;
}

.status-pill {
  min-width: 92rpx;
  height: 48rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
  color: #4374a5;
  background: rgba(176, 221, 250, 0.36);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.status-pill--consignment-user {
  background: rgba(182, 233, 210, 0.75);
  color: #2e9f7f;
}

.status-pill--normal {
  color: #57708e;
  background: rgba(234, 241, 250, 0.9);
}

.panel-scroll {
  height: calc(100vh - 420rpx - env(safe-area-inset-top));
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.panel-scroll--sold {
  padding-bottom: 240rpx;
}

.top-more {
  width: 60rpx;
  text-align: center;
  color: #556884;
  font-size: 44rpx;
  line-height: 1;
}

.hero-user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  border-radius: 34rpx;
  border: 2rpx solid rgba(192, 222, 244, 0.9);
}

.section-card,
.dropdown-card {
  padding: 32rpx;
  margin-bottom: 20rpx;
  border-radius: 34rpx;
  border: 2rpx solid rgba(192, 222, 244, 0.9);
}

.hero-name-line,
.section-head {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 14rpx;
}

.section-head {
  justify-content: space-between;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.line,
.tiny-actions,
.dialog-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.stats-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.stat-card {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  border-radius: 34rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #2a3855;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7589a1;
}

.stat-sub {
  margin-top: 2rpx;
  font-size: 24rpx;
  color: #8a9db3;
  line-height: 1.5;
}

.mini-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2b3d56;
}

.tiny-btn {
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #6e82a0;
  background: rgba(243, 249, 255, 0.95);
  display: inline-flex;
  align-items: center;
}

.tiny-btn--primary {
  color: #28445f;
  background: linear-gradient(180deg, #d6ebff 0%, #bce0fb 100%);
  min-width: 96rpx;
  justify-content: center;
}

.tiny-btn--ghost {
  color: #5a84b2;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(158, 207, 244, 0.95);
  min-width: 96rpx;
  justify-content: center;
}

.line {
  padding: 18rpx 0;
  border-bottom: 2rpx solid rgba(217, 236, 248, 0.82);
  font-size: 28rpx;
  color: #637990;
}

.line text:last-child {
  color: #2b3b54;
  font-weight: 600;
}

/* 可编辑信息行 */
.info-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid rgba(217, 236, 248, 0.82);
  font-size: 28rpx;
  color: #637990;
}

.info-line:last-child {
  border-bottom: 0;
}

.info-line.editable {
  cursor: pointer;
}

.info-line.editable:active {
  background: rgba(176, 221, 250, 0.1);
}

.info-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #2b3b54;
  font-weight: 600;
}

.edit-icon {
  color: #4b84bf;
  font-size: 24rpx;
}

.info-line.readonly .info-value {
  color: #6f87a5;
}

.field-group {
  margin-top: 10rpx;
}

.field-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  gap: 16rpx;
}

.field-label {
  color: #617790;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
  width: 128rpx;
  white-space: nowrap;
}

.section-card .field-input {
  width: 78% !important;
  min-width: 0;
  max-width: none;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(198, 222, 241, 0.95);
  color: #8b9bb0;
  background: rgba(252, 254, 255, 0.9);
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  flex: 1;
  margin-left: auto;
}

.field-input-wrap {
  position: relative;
  width: 100%;
  flex: 1;
  margin-left: auto;
}

.field-input-wrap--rate {
  flex: 0 0 200rpx;
  width: 200rpx;
  transform: translateX(-4rpx);
}

.field-suffix {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  font-weight: 700;
  color: #8b9bb0;
}

.field-input-wrap .field-input {
  padding-right: 28rpx;
}

.field-row--first {
  border-top: 2rpx solid rgba(217, 236, 248, 0.82);
  padding-top: 16rpx;
}

.field-input--error {
  border-color: #f4b3c1;
}

.field-input--percent {
  justify-content: space-between;
}

.field-input--rate {
  width: 100% !important;
}

.field-input--fixed {
  width: 400rpx !important;
  flex: 0 0 400rpx;
}

.hero-side-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.65);
}

.rate-hot {
  color: #e55472;
}

.perm-sub {
  margin-top: 6rpx;
  color: #8a99af;
  font-size: 24rpx;
  line-height: 1.5;
}

.no-divider {
  border-bottom: 0;
}

.goods-card {
  display: flex;
  gap: 32rpx;
  align-items: flex-start;
  padding: 24rpx;
}

.goods-media {
  position: relative;
  flex-shrink: 0;
}

.goods-thumb {
  width: 160rpx;
  height: 200rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255, 215, 230, 0.7), rgba(176, 221, 250, 0.9));
  color: #fff;
  font-size: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.goods-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.goods-star {
  font-size: 44rpx;
  color: #fff;
}

.quality-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: #42BC8E;
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  padding: 6rpx 14rpx;
  border-radius: 18rpx;
}

.list-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.goods-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.list-title {
  margin-bottom: 0;
  flex: 1;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
}

.list-subtitle {
  margin-top: 0;
  margin-bottom: 0;
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #68709A;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-bottom-row {
  margin-top: 4rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-bottom-spacer {
  flex: 1;
}

.goods-series {
  max-width: 300rpx;
  color: #68709A;
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 500;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-status-pill {
  min-width: 90rpx;
  height: 48rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.goods-status-pill--up {
  color: #4b84bf;
  background: rgba(176, 221, 250, 0.42);
}

.settle-user-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.settle-counter {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 230, 240, 0.85);
  color: #4b5d77;
  font-size: 24rpx;
  font-weight: 700;
}

.goods-card--settle {
  align-items: center;
}

.settle-check {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #2f4661;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.settle-check--off {
  background: transparent;
  border: 2rpx solid #b6c8df;
}

.goods-card--disabled {
  opacity: 0.7;
}

.extra-num {
  font-size: 28rpx;
  color: #8892B0;
  font-weight: 500;
}

.price {
  color: #E55472;
  font-size: 32rpx;
  font-weight: 800;
}

.switch {
  width: 104rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #d1d5db;
  position: relative;
  transition: background 0.3s;
}

.switch--on {
  background: linear-gradient(90deg, #d9b5d5 0%, #a9bdf8 100%);
}

.switch::before {
  content: "";
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #fff;
  transition: transform 0.3s;
}

.switch--on::before {
  transform: translateX(40rpx);
}

.ghost-btn {
  display: block;
  width: calc(100% + 24rpx);
  box-sizing: border-box;
  height: 92rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 163, 182, 0.9);
  background: rgba(255, 245, 248, 0.92);
  color: #d55e79;
  font-size: 32rpx;
  line-height: 92rpx;
  font-weight: 700;
  margin-top: 22rpx;
  margin-left: -12rpx;
  margin-right: 0;
  padding: 0;
}

.permission-row {
  margin-top: 6rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.sold-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(242, 248, 255, 0.98);
  border-top: 2rpx solid rgba(191, 212, 234, 0.9);
  padding: 14rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
}

.sold-total {
  border-radius: 20rpx;
  background: rgba(255, 225, 238, 0.7);
  padding: 10rpx 16rpx;
}

.sold-total-label {
  color: #7e90aa;
  font-size: 24rpx;
  line-height: 1.5;
}

.sold-total-amount {
  margin-top: 2rpx;
  color: #e55472;
  font-size: 44rpx;
  font-weight: 700;
}

.sold-actions {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
}

.sold-action {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(191, 212, 234, 0.9);
  background: #fff;
  color: #3a4a63;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sold-action--primary {
  border: 0;
  color: #2f3d57;
  background: linear-gradient(90deg, #f5c7dd 0%, #a8ccf2 100%);
}

.sold-action--full {
  width: 100%;
}

.settlement-list-card {
  padding: 10rpx 20rpx;
}

.settlement-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid rgba(217, 236, 248, 0.82);
}

.settlement-item-row:last-child {
  border-bottom: 0;
}

.settlement-item-thumb-wrap {
  flex: 0 0 70rpx;
}

.settlement-item-thumb {
  width: 84rpx;
  height: 84rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255, 215, 230, 0.72), rgba(176, 221, 250, 0.88));
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.settlement-item-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.settlement-item-main {
  flex: 1;
  min-width: 0;
}

.settlement-item-main .list-title {
  font-size: 32rpx;
  line-height: 1.35;
}

.settlement-item-main .list-subtitle {
  margin-top: 4rpx;
  font-size: 24rpx;
}

.settlement-item-side {
  flex-shrink: 0;
  text-align: right;
}

.settlement-item-side .price {
  font-size: 32rpx;
}

.settlement-item-side .list-subtitle {
  margin-top: 4rpx;
  font-size: 24rpx;
}

.settlement-summary-card .line {
  font-size: 28rpx;
  line-height: 1.6;
}

.settlement-summary-card .line .rate-hot {
  font-size: 48rpx;
  font-weight: 800;
}

.money-text-red {
  color: #E55472;
  font-weight: 700;
}

.settlement-summary-card .line text:last-child {
  color: #E55472;
}

.settlement-hint {
  font-size: 24rpx;
  color: #96a7bf;
  line-height: 1.5;
}

/* ===== 照片上传网格 ===== */
.photo-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  border-radius: 20rpx;
  overflow: hidden;
}

.photo-item image,
.photo-item .photo-add-icon {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.photo-img {
  border-radius: 20rpx;
}

.photo-delete-btn {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2;
}

.photo-delete-btn::before,
.photo-delete-btn::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  background: #ffffff;
  border-radius: 999rpx;
  transform: translate(-50%, -50%) rotate(45deg);
}

.photo-delete-btn::before {
  width: 20rpx;
  height: 4rpx;
}

.photo-delete-btn::after {
  width: 4rpx;
  height: 20rpx;
}

.photo-add {
  border: 2rpx dashed #a0c4e8;
  background: rgba(255, 255, 255, 0.72);
}

.photo-add-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add-icon::before,
.photo-add-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  background: #4a90d9;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.photo-add-icon::before {
  width: 48rpx;
  height: 5rpx;
}

.photo-add-icon::after {
  width: 5rpx;
  height: 48rpx;
}

.settlement-income-wrap {
  margin-top: 14rpx;
  margin-bottom: 12rpx;
  height: 84rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(198, 222, 241, 0.95);
  background: rgba(252, 254, 255, 0.9);
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.settlement-income-prefix {
  color: #8ea1bb;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 10rpx;
}

.settlement-income-input {
  flex: 1;
  height: 100%;
  border: 0;
  background: transparent;
  padding: 0;
  font-size: 32rpx;
  color: #E55472;
  font-weight: 700;
}

.settlement-desc {
  color: #8395b0;
  font-size: 24rpx;
  line-height: 1.6;
}

.voucher-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.voucher-tile {
  height: 90rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(176, 196, 214, 0.88);
  color: #7f96af;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 250, 255, 0.9);
}

.voucher-tile--fill {
  border-style: solid;
  background: linear-gradient(180deg, rgba(255, 215, 230, 0.75), rgba(176, 221, 250, 0.9));
  color: #fff;
}

.sold-footer .sold-action--full {
  height: 88rpx;
  font-size: 32rpx;
  letter-spacing: 2rpx;
}

.settle-record-total {
  text-align: right;
}

.settled-group-head {
  margin: 8rpx 6rpx 10rpx;
  display: flex;
  justify-content: space-between;
  color: #8395b0;
  font-size: 24rpx;
  font-weight: 700;
}

.settled-record-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 12rpx;
}

.settled-record-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255, 215, 230, 0.65), rgba(176, 221, 250, 0.85));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.settled-record-side {
  text-align: right;
  flex-shrink: 0;
}

.settled-detail-top {
  padding: 24rpx;
}

.settled-detail-main-money {
  margin-top: 6rpx;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 800;
  color: #2f415b;
}

.settled-detail-nums {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.settled-detail-nums > view {
  border-left: 2rpx solid rgba(217, 236, 248, 0.82);
  padding-left: 12rpx;
}

.settled-detail-nums > view:first-child {
  border-left: 0;
  padding-left: 0;
}

.permission-copy {
  flex: 1;
}

.permission-title {
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #2b3551;
}

.permission-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6f87a5;
  line-height: 1.5;
}

.option {
  margin-top: 12rpx;
  height: 64rpx;
  border-radius: 24rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #647e97;
  display: flex;
  align-items: center;
}

.option--active {
  background: rgba(176, 221, 250, 0.32);
  color: #2d4a6b;
}

.bottom-bar {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 34rpx rgba(116, 148, 181, 0.2);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bottom-info {
  font-size: 28rpx;
  color: #415b79;
}

.bottom-info text {
  display: block;
  margin-top: 6rpx;
  color: #768da7;
}

.primary-btn {
  height: 88rpx;
  border-radius: 24rpx;
  padding: 0 28rpx;
  background: linear-gradient(180deg, #c7e8ff 0%, #b0ddfa 100%);
  font-size: 32rpx;
  color: #28435d;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.submit-btn-like {
  justify-content: center;
  margin: 10rpx 0 24rpx;
}

.upload-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.upload-tile {
  height: 96rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(176, 196, 214, 0.88);
  color: #7f96af;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 250, 255, 0.9);
}

.upload-tile--fill {
  border-style: solid;
  background: linear-gradient(180deg, rgba(255, 215, 230, 0.75), rgba(176, 221, 250, 0.9));
  color: #fff;
}

.empty-state {
  padding: 52rpx 24rpx;
  text-align: center;
}

.empty-mark {
  margin: 0 auto 18rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 215, 230, 0.82), rgba(176, 221, 250, 0.9));
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f425c;
}

.empty-sub {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #7b90a8;
}

.dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(38, 50, 77, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.dialog-box {
  width: 100%;
  border-radius: 32rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 42rpx rgba(116, 148, 181, 0.12);
}

.dialog-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #25364f;
}

.dialog-text {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #6f839c;
}

.dialog-actions {
  margin-top: 22rpx;
}
