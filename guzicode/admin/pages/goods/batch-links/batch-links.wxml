<view class="subpage-shell">
  <view class="subpage">
    <view class="statusbar-spacer"></view>

    <view class="sub-header">
      <view class="back-chip" bindtap="goBack">‹</view>
      <view class="sub-title-group">
        <view class="sub-title">批量上架</view>
        <view class="sub-caption">共 {{items.length}} 件，需补充平台链接</view>
      </view>
    </view>

    <view class="sub-scroll">
      <view class="link-editor-list">
        <view class="link-editor-card" wx:for="{{items}}" wx:for-item="product" wx:key="id">
          <view class="link-editor-head">
            <view class="link-editor-thumb">✦</view>
            <view class="link-editor-info">
              <view class="link-editor-title">{{product.title}}</view>
              <view class="link-editor-subtitle">#{{product.id}} · {{product.owner || '未知寄售'}}</view>
            </view>
          </view>

          <view class="link-editor-rows">
            <view class="link-row" wx:for="{{product.links}}" wx:for-item="link" wx:key="platform">
              <view class="platform-tag">{{link.platform}}</view>
              <view class="link-input-box">
                <input class="link-input" placeholder="请输入{{link.platform}}链接" placeholder-class="placeholder" value="{{link.url}}" bindinput="onUrlInput" data-id="{{product.id}}" data-index="{{index}}" />
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="submit-wrap">
        <button class="submit-btn" disabled="{{!canSubmit}}" bindtap="handleSubmit">提交批量上架</button>
      </view>
    </view>
  </view>
</view>
