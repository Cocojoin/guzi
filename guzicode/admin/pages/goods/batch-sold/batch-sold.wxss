@import "../../../../app.wxss";

.subpage-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.subpage {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.statusbar-spacer {
  height: calc(120rpx + env(safe-area-inset-top));
}

.sub-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 0 4rpx 28rpx;
  padding-right: calc(220rpx + env(safe-area-inset-right));
  box-sizing: border-box;
  min-height: 64rpx;
}

.back-chip {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #557087;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(217, 236, 248, 0.9);
  font-size: 36rpx;
  font-weight: 700;
}

.sub-title-group {
  flex: 1;
  min-width: 0;
}

.sub-title {
  color: #1a1a1a;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 800;
}

.sub-caption {
  margin-top: 6rpx;
  color: #8b7e9b;
  font-size: 24rpx;
  font-weight: 500;
}

.sub-scroll {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.form-section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(45, 76, 120, 0.06);
}

.section-title {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.required::after {
  content: "*";
  color: #e53935;
  margin-left: 6rpx;
}

.section-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-copy-tip {
  color: #9aa8bd;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.sold-list {
  display: flex;
  flex-direction: column;
}

.sold-item {
  padding: 24rpx 0 28rpx;
  border-bottom: 2rpx solid rgba(217, 236, 248, 0.5);
}

.sold-item:last-child {
  border-bottom: none;
}

.sold-card-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.sold-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 215, 230, 0.72), rgba(176, 221, 250, 0.88));
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sold-info {
  flex: 1;
  min-width: 0;
}

.sold-name {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.sold-stock {
  color: #8b7e9b;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.5;
}

.sold-stock-strong {
  color: #42bc8e;
  font-weight: 700;
}

.sold-form-row {
  margin-top: 20rpx;
  display: flex;
  gap: 18rpx;
  align-items: flex-end;
}

.sold-form-field {
  flex: 1;
  min-width: 0;
}

.sold-form-field--amount {
  flex: 1.34;
}

.sold-form-label {
  margin-bottom: 12rpx;
  color: #7f8ea7;
  font-size: 24rpx;
  font-weight: 600;
}

.qty-stepper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty-stepper-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  background: rgba(255, 255, 255, 0.96);
  color: #2a3f5a;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.qty-stepper-value-wrap {
  flex: 1;
  height: 64rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.qty-stepper-value {
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #2a3f5a;
  text-align: center;
}

.sold-amount-input {
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.sold-amount-prefix {
  color: #2a3f5a;
  font-size: 28rpx;
  font-weight: 800;
}

.sold-amount-field {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  line-height: 64rpx;
  color: #2a3f5a;
  font-size: 28rpx;
  font-weight: 700;
}

.summary-card {
  margin-bottom: 24rpx;
  padding: 26rpx 28rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  background: linear-gradient(90deg, rgba(255, 216, 230, 0.36) 0%, rgba(176, 221, 250, 0.34) 100%);
  box-shadow: 0 10rpx 24rpx rgba(118, 154, 190, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.summary-title {
  color: #8b7e9b;
  font-size: 30rpx;
  font-weight: 700;
}

.summary-sub {
  margin-top: 6rpx;
  color: #9aa8bd;
  font-size: 24rpx;
  font-weight: 500;
}

.summary-amount {
  color: #2a3f5a;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
  flex-shrink: 0;
}

.remark-input-box {
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.remark-input {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.placeholder {
  color: #a5b3c7;
  font-weight: 400;
}

.submit-btn {
  height: 96rpx;
  width: 100%;
  border: 0;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #c0e7ff 0%, #b0ddfa 100%);
  color: #24435a;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 28rpx rgba(176, 221, 250, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
}

.submit-btn::after {
  border: 0;
}
