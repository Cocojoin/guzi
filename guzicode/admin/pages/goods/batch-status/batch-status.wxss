@import "../../../../app.wxss";

.subpage-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.subpage {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.statusbar-spacer {
  height: calc(120rpx + env(safe-area-inset-top));
}

.sub-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 0 4rpx 28rpx;
  padding-right: calc(220rpx + env(safe-area-inset-right));
  box-sizing: border-box;
  min-height: 64rpx;
}

.back-chip {
  width: 64rpx;
  height: 64rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #557087;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(217, 236, 248, 0.9);
  font-size: 40rpx;
  font-weight: 900;
}

.sub-title-group {
  flex: 1;
  min-width: 0;
}

.sub-title {
  color: #24364a;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 900;
}

.sub-caption {
  margin-top: 6rpx;
  color: #6b7f95;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.sub-scroll {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.mini-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  box-shadow: 0 20rpx 44rpx rgba(45, 76, 120, 0.09);
}

.mini-title {
  color: #24364a;
  font-size: 28rpx;
  font-weight: 900;
  margin-bottom: 20rpx;
}

.required::after {
  content: "*";
  color: #e55472;
  margin-left: 6rpx;
  font-weight: 900;
}

.batch-status-summary {
  padding: 24rpx;
}

.batch-status-item {
  display: grid;
  grid-template-columns: 84rpx 1fr auto;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 32rpx;
  background: rgba(242, 250, 255, 0.82);
  margin-top: 14rpx;
}

.batch-status-thumb {
  width: 84rpx;
  height: 84rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(145deg, #8ccbff, #b7a8ff 52%, #ffb8d1);
  font-size: 32rpx;
  font-weight: 900;
}

.batch-status-name {
  color: #24364a;
  font-size: 28rpx;
  font-weight: 900;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-pill {
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #4b84bf;
  background: rgba(176, 221, 250, 0.28);
  font-size: 24rpx;
  line-height: 48rpx;
  font-weight: 900;
  white-space: nowrap;
}

.status-pill--down,
.status-pill--settled {
  color: #718097;
  background: rgba(148, 163, 184, 0.16);
}

.status-pill--sold {
  color: #e55472;
  background: rgba(255, 230, 239, 0.92);
}

.form-section {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  box-shadow: 0 20rpx 44rpx rgba(45, 76, 120, 0.09);
}

.status-choice-grid {
  display: grid;
  gap: 14rpx;
}

.status-choice {
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(242, 250, 255, 0.6);
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.status-choice.active {
  background: rgba(192, 231, 255, 0.4);
  border-color: rgba(74, 144, 217, 0.3);
}

.choice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.choice-desc {
  font-size: 24rpx;
  color: #8b7e9b;
  font-weight: 500;
  line-height: 1.5;
}

.input-box {
  margin-top: 12rpx;
  min-height: 84rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  border: 2rpx solid #d9ecf8;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.input {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #334155;
}

.placeholder {
  color: #a5b3c7;
  font-weight: 500;
}

.button {
  height: 96rpx;
  width: 100%;
  border: 0;
  border-radius: 48rpx;
  background: linear-gradient(180deg, #c0e7ff 0%, #b0ddfa 100%);
  color: #24435a;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 34rpx rgba(176, 221, 250, 0.28);
  padding: 0 40rpx;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
}

.button::after {
  border: 0;
}
