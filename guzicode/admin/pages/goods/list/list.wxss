@import "../../../../app.wxss";

page {
  background: linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #F7FCFF;
  z-index: 999;
}

.custom-nav-status {
  width: 100%;
}

.custom-nav-title-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.custom-nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.management-shell {
  min-height: 100vh;
  background: linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.management-page {
  min-height: 100vh;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 196rpx;
  box-sizing: border-box;
}

.management-page--with-bar {
  padding-bottom: 300rpx;
}

.management-header {
  position: relative;
  margin-bottom: 28rpx;
  display: block !important;
  width: 100%;
  box-sizing: border-box;
  padding-right: 0;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: -2rpx;
  width: 100%;
  box-sizing: border-box;
  flex: none;
}

.header-search {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.header-search-icon {
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid #79a7c7;
  border-radius: 50%;
  position: relative;
  box-sizing: border-box;
  flex: 0 0 22rpx;
  transform: translateX(2rpx);
}

.header-search-icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -6rpx;
  width: 10rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #79a7c7;
  transform: rotate(45deg);
}

.header-search-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(192, 231, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 4rpx;
}

.header-search-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #24364a;
  padding-left: 8rpx;
  box-sizing: border-box;
}

.header-search-placeholder {
  color: #9aa9bd;
  font-weight: 500;
}

.header-search-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(242, 250, 255, 0.9);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  color: #6c8aa3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
  flex: 0 0 40rpx;
}

.icon-button {
  width: 88rpx;
  height: 88rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: none;
  color: #79a7c7;
  font-size: 36rpx;
  position: relative;
  flex: 0 0 88rpx;
}

.add-btn {
  color: #79a7c7;
  font-weight: 300;
}

.add-icon-small {
  width: 34rpx;
  height: 34rpx;
  position: relative;
}

.add-icon-small::before,
.add-icon-small::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 999rpx;
  background: #79a7c7;
  transform: translate(-50%, -50%);
}

.add-icon-small::before {
  width: 34rpx;
  height: 5rpx;
}

.add-icon-small::after {
  width: 5rpx;
  height: 34rpx;
}

.filter-panel {
  margin-bottom: 36rpx;
  position: relative;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 12rpx 0 0;
  flex-wrap: nowrap;
}

.filter-dropdown {
  flex: 1;
  min-width: 0;
  max-width: 180rpx;
  height: 60rpx;
  padding: 0 14rpx;
  background: #ffffff;
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.filter-dropdown--active {
  border-color: #4a90d9;
  background: rgba(192, 231, 255, 0.3);
}

.filter-dropdown-text {
  color: #6f84a0;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
}

.filter-arrow {
  transform: scale(0.72);
  transform-origin: center;
  color: #70839b;
  font-size: 24rpx;
  transition: transform 0.2s;
}

.filter-arrow--up {
  transform: scale(0.72) rotate(180deg);
}

.dropdown-panel {
  position: relative;
  z-index: 100;
}

.dropdown-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
}

.dropdown-panel-content {
  position: absolute;
  top: 12rpx;
  left: 0;
  right: 0;
  max-height: 500rpx;
  overflow-y: auto;
  margin-top: 0;
  margin-left: 0;
  margin-right: 0;
  padding: 12rpx 0;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  box-shadow: 0 16rpx 40rpx rgba(45, 76, 120, 0.15);
  z-index: 101;
}

.dropdown-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  color: #546e7a;
  font-size: 28rpx;
  font-weight: 500;
}

.dropdown-option--active {
  color: #24435a;
  font-weight: 600;
  background: rgba(192, 231, 255, 0.3);
  border-radius: 18rpx;
  margin: 0 8rpx;
  padding: 20rpx 20rpx;
}

.dropdown-check {
  color: #4a90d9;
  font-size: 32rpx;
  font-weight: 700;
}

.batch-btn {
  margin-left: 0;
  flex: 0 0 auto;
  width: 90rpx;
  height: 60rpx;
  padding: 0;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  color: #6f84a0;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  line-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.management-page--with-bar .batch-btn {
  color: #6c8aa3;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  position: relative;
}

.goods-card {
  position: relative;
  padding: 32rpx;
  border-radius: 44rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(249, 252, 255, 0.9));
  border: 2rpx solid rgba(220, 233, 248, 0.92);
  box-shadow: 0 20rpx 44rpx rgba(45, 76, 120, 0.10);
  overflow: hidden;
}

.goods-card--disabled {
  opacity: 0.56;
}

.goods-card--sold {
  background: linear-gradient(180deg, rgba(250, 251, 253, 0.96), rgba(243, 246, 250, 0.92));
  border-color: rgba(223, 229, 238, 0.96);
}

.goods-card--sold .goods-title,
.goods-card--sold .goods-price,
.goods-card--sold .goods-meta-item,
.goods-card--sold .goods-owner {
  color: #97a3b5;
}

.goods-card--sold .goods-thumb {
  background:
    radial-gradient(circle at 72% 28%, rgba(255, 255, 255, 0.88) 0 10rpx, transparent 11rpx),
    linear-gradient(160deg, rgba(244, 247, 251, 0.92) 0%, rgba(227, 234, 242, 0.9) 100%);
}

.goods-card--batch {
  padding-left: 96rpx;
}

.goods-card--selected {
  border-color: rgba(176, 221, 250, 1);
  box-shadow:
    0 24rpx 52rpx rgba(45, 76, 120, 0.12),
    inset 0 0 0 4rpx rgba(176, 221, 250, 0.36);
}

.goods-main {
  display: flex;
  align-items: stretch;
  gap: 24rpx;
}

.goods-media {
  position: relative;
  width: 160rpx;
  flex: 0 0 160rpx;
  align-self: stretch;
}

.quality-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 18rpx;
  z-index: 2;
}

.quality-tag--flaw {
  background: #e55472;
}

.quality-tag--clean {
  background: #42BC8E;
}

.goods-thumb {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 72% 28%, rgba(255, 255, 255, 0.94) 0 10rpx, transparent 11rpx),
    linear-gradient(160deg, rgba(255, 255, 255, 0.86) 0%, rgba(176, 221, 250, 0.8) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.goods-image {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: center;
}

.goods-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  padding-right: 12rpx;
  gap: 10rpx;
}

.goods-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.goods-title {
  color: #23304d;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
  letter-spacing: 0;
  flex: 1;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.goods-meta-item {
  color: #7d8ba4;
  font-size: 24rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price {
  color: #e14d69;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 800;
}

.goods-type-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-owner {
  font-size: 28rpx;
  color: #8892B0;
  font-weight: 500;
  line-height: 1.5;
}

.goods-star {
  width: 34rpx;
  height: 34rpx;
  position: relative;
}

.goods-star::before,
.goods-star::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  background: rgba(255, 255, 255, 0.96);
  transform: translate(-50%, -50%);
}

.goods-star::before {
  width: 34rpx;
  height: 12rpx;
  border-radius: 999rpx;
}

.goods-star::after {
  width: 12rpx;
  height: 34rpx;
  border-radius: 999rpx;
}

.status-pill {
  flex: 0 0 auto;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #4b84bf;
  background: rgba(176, 221, 250, 0.28);
  font-size: 24rpx;
  line-height: 48rpx;
  font-weight: 900;
}

.status-pill--up {
  color: #4b84bf;
  background: rgba(176, 221, 250, 0.28);
}

.status-pill--sold {
  color: #1e8e69;
  background: rgba(120, 199, 162, 0.22);
}

.status-pill--down {
  color: #718097;
  background: rgba(148, 163, 184, 0.16);
}

.status-pill--settled {
  color: #7b7f92;
  background: rgba(148, 163, 184, 0.18);
}

.select-col {
  position: absolute;
  left: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
}

.select-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #bed1ec;
  background: rgba(255, 255, 255, 0.74);
  box-sizing: border-box;
  position: relative;
}

.select-circle--checked {
  border-color: #111b34;
  background: #111b34;
}

.select-circle--checked::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 12rpx;
  height: 20rpx;
  border-right: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: translate(-50%, -65%) rotate(45deg);
}

.select-circle--disabled {
  border-color: #d4dbe6;
  background: #edf1f7;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: space-around;
  padding: 16rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(245, 250, 255, 0.82);
  border-top: 2rpx solid rgba(183, 204, 229, 0.58);
  box-shadow: 0 -14rpx 34rpx rgba(118, 154, 190, 0.12);
  backdrop-filter: blur(18px);
}

.nav-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8c9bb0;
}

.nav-icon {
  width: 72rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon-image {
  width: 34rpx;
  height: 34rpx;
  display: block;
}

.nav-label {
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 30rpx;
}

.nav-item--active {
  color: #111b34;
  font-weight: 700;
}

.nav-item--active .nav-icon {
  background: linear-gradient(180deg, #ffe2ec 0%, #cfe7ff 100%);
  border: 0;
  border-radius: 999rpx;
  box-shadow: 0 16rpx 36rpx rgba(45, 76, 120, 0.12);
}


.selection-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(108rpx + env(safe-area-inset-bottom));
  z-index: 30;
  min-height: 104rpx;
  padding: 24rpx 28rpx 28rpx;
  border-radius: 0;
  background: rgba(255, 255, 255, 0.95);
  border-top: 2rpx solid rgba(217, 236, 248, 0.78);
  box-shadow: 0 -12rpx 30rpx rgba(83, 112, 151, 0.12);
  backdrop-filter: blur(18px);
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-sizing: border-box;
}

.selection-meta {
  display: grid;
  grid-template-columns: 48rpx 1fr;
  column-gap: 16rpx;
  align-items: center;
  min-width: 0;
  flex: 1;
  overflow: hidden;
}

.select-circle--bar {
  width: 44rpx;
  height: 44rpx;
}

.selection-copy {
  min-width: 0;
}

.selection-title {
  color: #111b34;
  font-size: 28rpx;
  line-height: 32rpx;
  font-weight: 700;
  white-space: nowrap;
}

.selection-count {
  margin-top: 2rpx;
  color: #7c8ca6;
  font-size: 24rpx;
  line-height: 28rpx;
  white-space: nowrap;
}

.selection-count text {
  color: #e55472;
  font-weight: 800;
}

.selection-actions {
  display: flex;
  gap: 20rpx;
  flex-shrink: 0;
  justify-content: flex-end;
}

.ghost-btn,
.danger-btn {
  width: auto;
  min-width: 0;
  max-width: 200rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: 0;
  font-size: 28rpx;
  font-weight: 700;
  padding: 0 28rpx;
  margin: 0;
  white-space: nowrap;
  box-sizing: border-box;
}

.ghost-btn {
  color: #24435a;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  box-shadow: none;
}

.danger-btn {
  color: #d94d70;
  background: rgba(255, 230, 239, 0.72);
  border: 2rpx solid rgba(255, 199, 219, 0.82);
  box-shadow: none;
}

.ghost-btn::after,
.danger-btn::after {
  border: 0;
}

.empty-card {
  margin-top: 60rpx;
  padding: 52rpx 32rpx;
  text-align: center;
}

.empty-title {
  color: #17213a;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-hint {
  margin-top: 12rpx;
  color: #7d8ba4;
  font-size: 28rpx;
  line-height: 1.6;
}

.list-refresh-tip {
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  font-weight: 600;
}
