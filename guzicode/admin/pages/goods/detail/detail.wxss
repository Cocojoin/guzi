@import "../../../../app.wxss";

/* ===== 页面背景 ===== */
.detail-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%) !important;
}

.detail-page {
  min-height: 100vh;
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.detail-page--with-sheet {
  overflow: hidden;
}

/* ===== 状态栏占位 ===== */
.detail-page .statusbar-spacer {
  height: calc(120rpx + env(safe-area-inset-top));
}

/* ===== 顶部导航栏 ===== */
.detail-page .topbar {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding-right: calc(220rpx + env(safe-area-inset-right));
  box-sizing: border-box;
  min-height: 64rpx;
}

.detail-page .back-button {
  width: 64rpx !important;
  height: 64rpx !important;
  border-radius: 50% !important;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(217, 236, 248, 0.9);
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  flex: 0 0 64rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  z-index: 1;
}

.detail-page .back-button::before {
  content: "";
  width: 14rpx;
  height: 14rpx;
  border-left: 3rpx solid #4b617a;
  border-bottom: 3rpx solid #4b617a;
  transform: rotate(45deg);
  margin-right: 4rpx;
}

.detail-page .page-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: calc(100% - 340rpx);
  max-width: 420rpx;
  color: #1a1a1a;
  font-size: 44rpx !important;
  line-height: 1.2;
  font-weight: 800;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 表单卡片 ===== */
.detail-page .form-card {
  margin-bottom: 24rpx;
  padding: 32rpx 28rpx !important;
  border-radius: 28rpx !important;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(217, 236, 248, 0.92) !important;
  box-shadow: 0 8rpx 24rpx rgba(45, 76, 120, 0.06) !important;
}

/* ===== 卡片标签 ===== */
.detail-page .card-label {
  color: #8b7e9b;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
}

/* ===== 图片轮播 ===== */
.image-swiper {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.swiper-image {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
}

.swiper-placeholder {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
  background: rgba(242, 250, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a5b3c7;
  font-size: 28rpx;
}

/* ===== 商品摘要 ===== */
.summary-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.summary-title {
  color: #1a1a1a;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-price {
  color: #e53935;
  font-size: 40rpx;
  font-weight: 800;
  flex: 0 0 auto;
  margin-left: 16rpx;
}

.summary-sub {
  color: #8b7e9b;
  font-size: 28rpx;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.summary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tag-label {
  color: #8b7e9b;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 48rpx;
  display: flex;
  align-items: center;
}

.status-pill {
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.status-pill--down {
  background: rgba(160, 170, 185, 0.12);
  color: #8a9ab1;
}

.status-pill--sold {
  background: rgba(76, 175, 80, 0.12);
  color: #4caf50;
}

.status-pill--settled {
  background: rgba(255, 152, 0, 0.12);
  color: #ff9800;
}

.quality-badge {
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
  background: rgba(139, 126, 155, 0.1);
  color: #8b7e9b;
}

.quality-badge--clean {
  background: rgba(76, 175, 80, 0.1);
  color: #4caf50;
}

.quality-badge--flaw {
  background: rgba(255, 152, 0, 0.1);
  color: #ff9800;
}

.quality-badge--record {
  background: rgba(156, 136, 255, 0.1);
  color: #9c88ff;
}

/* ===== 统计数据 ===== */
.summary-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(232, 237, 242, 0.8);
}

.stat-item {
  text-align: center;
}

.stat-value {
  color: #1a1a1a;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.2;
}

.stat-label {
  color: #8c9cb2;
  font-size: 24rpx;
  font-weight: 600;
  margin-top: 4rpx;
}

/* ===== 寄售用户行 ===== */
.owner-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.owner-row--sub {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(232, 237, 242, 0.7);
}

.owner-row-label {
  color: #8b7e9b;
  font-size: 28rpx;
  font-weight: 600;
}

.owner-row-name {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 600;
}

/* ===== 信息行 ===== */
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 2rpx solid rgba(232, 237, 242, 0.5);
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-row:first-child {
  padding-top: 0;
}

.info-label {
  color: #8b7e9b;
  font-size: 28rpx;
  font-weight: 600;
  flex: 0 0 auto;
}

.info-value {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 500;
  text-align: right;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-left: 16rpx;
}

/* ===== 链接列表 ===== */
.detail-links {
  margin-top: 0;
}

.link-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 2rpx solid rgba(232, 237, 242, 0.5);
}

.link-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.link-item:first-child {
  padding-top: 0;
}

.link-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.link-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.link-platform-tag {
  flex: 0 0 auto;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: rgba(242, 250, 255, 0.86);
  color: #5f708b;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 64rpx;
  text-align: center;
  white-space: nowrap;
}

.link-url-text {
  flex: 1;
  min-width: 0;
  color: #4a90d9;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-copy-btn {
  flex: 0 0 auto;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: rgba(74, 144, 217, 0.1);
  color: #4a90d9;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 64rpx;
  margin-left: 12rpx;
}

.empty-hint {
  color: #a5b3c7;
  font-size: 28rpx;
  text-align: center;
  padding: 20rpx 0;
}

/* ===== 备注 ===== */
.remark-content {
  color: #3e546e;
  font-size: 28rpx;
  line-height: 40rpx;
}

/* ===== 寄售用户 ===== */
.owner-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.owner-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #c0e7ff 0%, #b0ddfa 100%);
  color: #24435a;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
}

.owner-name {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 600;
}

/* ===== 操作记录 ===== */
.log-item {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 2rpx solid rgba(232, 237, 242, 0.5);
}

.log-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.log-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #4a90d9;
  flex: 0 0 12rpx;
  margin-top: 10rpx;
}

.log-content {
  flex: 1;
  min-width: 0;
}

.log-text {
  color: #3e546e;
  font-size: 28rpx;
  line-height: 1.5;
}

.log-time {
  color: #a5b3c7;
  font-size: 24rpx;
  margin-top: 4rpx;
}

/* ===== 底部操作栏 ===== */
.detail-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 176rpx;
  padding: 32rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-sizing: border-box;
  z-index: 10;
  width: 100%;
}

.detail-action-bar .action-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 0 20rpx;
  border: 0;
  margin: 0 !important;
  flex: 1;
  min-width: 0;
}

.action-btn::after {
  border: 0;
}

.action-btn--primary {
  background: linear-gradient(180deg, #c0e7ff 0%, #b0ddfa 100%);
  color: #24435a;
  text-align: center;
}

.action-btn--light {
  background: rgba(255, 255, 255, 0.9);
  color: #4a90d9;
  border: 2rpx solid rgba(74, 144, 217, 0.3);
}

.action-btn--danger {
  background: #ffffff;
  color: #e53935;
  border: 2rpx solid rgba(74, 144, 217, 0.3);
}

/* ===== 底部弹窗 ===== */
.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(38, 50, 77, 0.28);
  z-index: 50;
}

.sheet-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 85vh;
  padding: 24rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-radius: 36rpx 36rpx 0 0;
  border-top: 2rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 -20rpx 50rpx rgba(116, 148, 181, 0.16);
  z-index: 51;
  overflow-y: auto;
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e0e0e0;
  margin: 0 auto 20rpx;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-title {
  color: #1a1a1a;
  font-size: 44rpx;
  font-weight: 800;
}

.sheet-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  color: #666;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sheet-card {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  margin-bottom: 24rpx;
}

.sheet-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex: 0 0 88rpx;
}

.sheet-thumb-img {
  width: 88rpx;
  height: 88rpx;
}

.sheet-thumb-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(200, 220, 240, 0.3);
}

.sheet-card-main {
  flex: 1;
  min-width: 0;
}

.sheet-card-title {
  color: #1a1a1a;
  font-size: 32rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-card-sub {
  color: #8c9cb2;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.sheet-section {
  margin-bottom: 24rpx;
}

.sheet-section-title {
  color: #8b7e9b;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.sheet-section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.sheet-section-side {
  color: #a0aec0;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.sheet-required {
  color: #ff6f8f;
}

.status-choice-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.status-choice {
  height: 84rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  color: #5f708b;
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx solid transparent;
}

.status-choice--active {
  color: #21314a;
  background: #dff2ff;
  border-color: rgba(121, 167, 199, 0.3);
}

/* ===== 步进器 ===== */
.stepper-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.stepper-btn {
  width: 84rpx;
  height: 84rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #4a90d9;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stepper-value {
  flex: 1;
  text-align: center;
  color: #1a1a1a;
  font-size: 36rpx;
  font-weight: 800;
}

.stepper-hint {
  text-align: center;
  color: #a5b3c7;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.sheet-money-input {
  margin-top: 18rpx;
  height: 92rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.sheet-money-prefix {
  color: #2f435f;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.sheet-money-field {
  flex: 1;
  min-width: 0;
  height: 92rpx;
  line-height: 92rpx;
  color: #2f435f;
  font-size: 38rpx;
  font-weight: 800;
}

.sheet-money-tail {
  color: #bac4d3;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.sheet-note {
  color: #8a9ab1;
  font-size: 24rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.sheet-submit .submit-btn {
  width: 100% !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border: 0 !important;
  border-radius: 28rpx !important;
  background: linear-gradient(180deg, #c0e7ff 0%, #b0ddfa 100%) !important;
  color: #24435a;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 28rpx rgba(176, 221, 250, 0.28);
  margin-top: 0 !important;
  padding: 0 !important;
}

.sheet-submit .submit-btn::after {
  border: 0;
}

.image-viewer {
  position: fixed;
  inset: 0;
  z-index: 30;
}

.image-viewer-mask {
  position: absolute;
  inset: 0;
  background: rgba(10, 16, 24, 0.92);
}

.image-viewer-panel {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: calc(56rpx + env(safe-area-inset-top)) 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.image-viewer-top {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  margin-top: 40rpx;
  margin-bottom: 28rpx;
}

.image-viewer-close {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.image-viewer-swiper {
  flex: 1;
  min-height: 0;
}

.image-viewer-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-viewer-image {
  width: 100%;
  height: 100%;
}

.image-viewer-footer {
  padding-top: 24rpx;
}

.image-download-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border: 0;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #c0e7ff 0%, #b0ddfa 100%);
  color: #24435a;
  font-size: 32rpx;
  font-weight: 700;
}

.image-download-btn::after {
  border: 0;
}
