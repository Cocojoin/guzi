@import "../../../../app.wxss";

/* ===== 页面背景（同注册登录页） ===== */
.upload-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 215, 230, 0.5), transparent 22%),
    radial-gradient(circle at right 25%, rgba(201, 194, 255, 0.5), transparent 20%),
    linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%) !important;
}

.upload-page {
  min-height: 100vh;
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== 状态栏占位 ===== */
.upload-page .statusbar-spacer {
  height: calc(120rpx + env(safe-area-inset-top));
}

/* ===== 顶部导航栏 ===== */
.upload-page .topbar {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding-right: calc(220rpx + env(safe-area-inset-right));
  box-sizing: border-box;
  min-height: 64rpx;
}

.upload-page .back-button {
  width: 64rpx !important;
  height: 64rpx !important;
  border-radius: 50% !important;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(217, 236, 248, 0.9);
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  flex: 0 0 64rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  z-index: 1;
}

.upload-page .back-button::before {
  content: "";
  width: 14rpx;
  height: 14rpx;
  border-left: 3rpx solid #4b617a;
  border-bottom: 3rpx solid #4b617a;
  transform: rotate(45deg);
  margin-right: 4rpx;
}

.upload-page .page-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: calc(100% - 340rpx);
  max-width: 420rpx;
  color: #1a1a1a;
  font-size: 44rpx !important;
  line-height: 1.2;
  font-weight: 800;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 商品编号栏 ===== */
.product-id-bar {
  margin-bottom: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  color: #8b7e9b;
  font-size: 28rpx;
  font-weight: 600;
}

/* ===== 表单卡片（覆盖全局 .form-card） ===== */
.upload-page .form-card {
  margin-bottom: 24rpx;
  padding: 32rpx 28rpx !important;
  border-radius: 32rpx !important;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(217, 236, 248, 0.92) !important;
  box-shadow: 0 18rpx 42rpx rgba(116, 148, 181, 0.12) !important;
}

/* ===== 卡片标签 ===== */
.upload-page .card-label {
  color: #8b7e9b;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
}

.upload-page .card-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.upload-page .card-label-row .card-label {
  margin-bottom: 0;
}

.upload-page .char-count {
  color: #8c9cb2;
  font-size: 24rpx;
  font-weight: 600;
}

.upload-page .required {
  color: #e53935;
  font-size: 28rpx;
}

/* ===== 照片上传网格 ===== */
.photo-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  border-radius: 20rpx;
  overflow: hidden;
}

.photo-item image,
.photo-item .photo-add-icon {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.photo-img {
  border-radius: 20rpx;
}

.photo-cover-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 32rpx;
  z-index: 1;
}

.photo-delete-btn {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2;
}

.photo-delete-btn::before,
.photo-delete-btn::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  background: #ffffff;
  border-radius: 999rpx;
  transform: translate(-50%, -50%) rotate(45deg);
}

.photo-delete-btn::before {
  width: 20rpx;
  height: 4rpx;
}

.photo-delete-btn::after {
  width: 4rpx;
  height: 20rpx;
}

.photo-add {
  border: 2rpx dashed #a0c4e8;
  background: rgba(255, 255, 255, 0.72);
}

.photo-add-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add-icon::before,
.photo-add-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  background: #4a90d9;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.photo-add-icon::before {
  width: 48rpx;
  height: 5rpx;
}

.photo-add-icon::after {
  width: 5rpx;
  height: 48rpx;
}

.photo-hint {
  margin-top: 10rpx;
  color: #8c9cb2;
  font-size: 24rpx;
  font-weight: 600;
}

/* ===== 表单字段（覆盖全局 .form-field） ===== */
.upload-page .form-field {
  display: block !important;
  height: auto !important;
  padding: 0 !important;
  border-radius: 0 !important;
  border: none !important;
  background: transparent !important;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.upload-page .form-field:last-child {
  margin-bottom: 0;
}

/* ===== 并排字段布局 ===== */
.upload-page .field-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.upload-page .field-row:last-child {
  margin-bottom: 0;
}

.upload-page .field-col {
  flex: 1;
  min-width: 0;
}

.upload-page .field-row--3 .field-col {
  flex: 1;
  min-width: 0;
}

/* 三列模式下分段选择器改为纵向堆叠 */
.upload-page .field-row--3 .seg-row {
  grid-template-columns: 1fr;
  gap: 8rpx;
}

.upload-page .field-row--3 .seg-item {
  height: 64rpx;
  font-size: 24rpx;
}

/* ===== 输入框（覆盖全局 .field-input） ===== */
.upload-page .field-input {
  flex: unset !important;
  width: 100% !important;
  height: 84rpx !important;
  padding: 0 24rpx !important;
  border-radius: 24rpx !important;
  border: 2rpx solid #e8edf2 !important;
  background: rgba(255, 255, 255, 0.92) !important;
  display: flex !important;
  align-items: center !important;
  box-sizing: border-box;
  font-size: 28rpx;
}

.upload-page .field-input-text {
  width: 100%;
  height: 84rpx;
  font-size: 32rpx;
  color: #1a1a1a;
  line-height: 84rpx;
  font-weight: 500;
}

.upload-page .placeholder {
  color: #a5b3c7;
  font-weight: 400;
}

/* ===== 下拉选择器 ===== */
.upload-page .picker-input {
  justify-content: space-between;
}

.upload-page .owner-picker-content {
  flex: 1;
  min-width: 0;
}

.upload-page .owner-selected-hint {
  margin-top: 10rpx;
  color: #8c9cb2;
  font-size: 24rpx;
  font-weight: 600;
}

.upload-page .is-placeholder {
  color: #a5b3c7;
}

.upload-page .field-dropdown {
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(217, 236, 248, 0.96);
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.upload-page .field-dropdown--active {
  border-color: #4a90d9;
  background: rgba(192, 231, 255, 0.3);
}

.upload-page .field-dropdown-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.upload-page .field-dropdown-arrow {
  color: #70839b;
  font-size: 24rpx;
  transform: scale(0.72);
  transition: transform 0.2s;
}

.upload-page .field-dropdown-arrow--up {
  transform: scale(0.72) rotate(180deg);
}

.upload-page .dropdown-panel {
  position: relative;
  z-index: 15;
  margin-top: 8rpx;
}

.upload-page .dropdown-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
}

.upload-page .dropdown-panel-content {
  padding: 12rpx 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  box-shadow: 0 12rpx 32rpx rgba(45, 76, 120, 0.1);
}

.upload-page .dropdown-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  color: #546e7a;
  font-size: 28rpx;
  font-weight: 500;
}

.upload-page .dropdown-option--active {
  color: #24435a;
  font-weight: 600;
  background: rgba(192, 231, 255, 0.3);
  border-radius: 18rpx;
  margin: 0 8rpx;
  padding: 20rpx 20rpx;
}

.upload-page .dropdown-check {
  color: #4a90d9;
  font-size: 32rpx;
  font-weight: 700;
}

.upload-page .picker-arrow-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8f4fd;
  position: relative;
  flex: 0 0 48rpx;
}

.upload-page .picker-arrow-btn::after {
  content: "";
  display: block;
  width: 10rpx;
  height: 10rpx;
  border-right: 3rpx solid #4a90d9;
  border-bottom: 3rpx solid #4a90d9;
  transform: rotate(45deg);
  position: absolute;
  left: 50%;
  top: 50%;
  margin-left: -5rpx;
  margin-top: -8rpx;
}

/* ===== 寄售用户底部弹窗 ===== */
.owner-popup {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 60;
}

.owner-popup-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(17, 24, 39, 0.24);
}

.owner-popup-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72vh;
  max-height: 960rpx;
  padding: 16rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, #ffffff 100%);
  box-shadow: 0 -16rpx 50rpx rgba(40, 60, 90, 0.16);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  animation: ownerPopupSlideUp 0.2s ease-out;
}

.owner-popup-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #d9e3ef;
  margin: 0 auto 18rpx;
}

.owner-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.owner-popup-action {
  min-width: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 44rpx;
}

.owner-popup-action--cancel {
  color: #718198;
}

.owner-popup-action--confirm {
  color: #5c9cf4;
  text-align: right;
}

.owner-popup-title {
  color: #24364f;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.owner-search-box {
  height: 84rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: #f4f7fb;
  border: 2rpx solid #e5edf6;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.owner-search-input {
  width: 100%;
  font-size: 28rpx;
  color: #24364f;
  font-weight: 500;
}

.owner-popup-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 20rpx;
}

.owner-section {
  margin-bottom: 20rpx;
}

.owner-section-title {
  margin-bottom: 14rpx;
  color: #8d9aae;
  font-size: 26rpx;
  font-weight: 600;
}

.owner-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 22rpx;
  margin-bottom: 16rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.owner-option--active {
  background: linear-gradient(180deg, rgba(255, 241, 245, 0.95) 0%, rgba(255, 248, 250, 0.95) 100%);
  border-color: rgba(255, 198, 214, 0.75);
}

.owner-option-avatar {
  flex: 0 0 72rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #f7d2ee 0%, #b5dfff 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.owner-option-main {
  flex: 1;
  min-width: 0;
}

.owner-option-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.owner-option-name {
  color: #24364f;
  font-size: 32rpx;
  font-weight: 700;
}

.owner-option-rate {
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  background: #dff5ea;
  color: #39a674;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.owner-option-meta {
  margin-top: 6rpx;
  color: #8d9aae;
  font-size: 26rpx;
  font-weight: 500;
}

.owner-option-check {
  flex: 0 0 40rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d5e0ee;
  background: #ffffff;
  position: relative;
}

.owner-option-check--active {
  background: #263951;
  border-color: #263951;
}

.owner-option-check--active::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 16rpx;
  height: 8rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: translate(-50%, -60%) rotate(-45deg);
}

.owner-empty {
  padding: 80rpx 24rpx;
  color: #9aabbe;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

@keyframes ownerPopupSlideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* ===== 自定义类型 ===== */
.upload-page .custom-wrap {
  margin-top: 12rpx;
}

/* ===== 分段选择 ===== */
.upload-page .seg-row {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.upload-page .seg-item {
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(242, 250, 255, 0.86);
  color: #5f708b;
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.upload-page .seg-item--active {
  color: #21314a;
  background: #dff2ff;
  border-color: rgba(121, 167, 199, 0.3);
}

/* ===== 购物平台链接 ===== */
.link-hint {
  margin-bottom: 0;
  color: #8a9ab1;
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 600;
}

.link-field {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.link-field:last-child {
  margin-bottom: 0;
}

.link-platform-tag {
  flex: 0 0 auto;
  height: 84rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e8edf2;
  background: rgba(255, 255, 255, 0.92);
  color: #5f708b;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 84rpx;
  text-align: center;
  white-space: nowrap;
  box-sizing: border-box;
}

.link-field .field-input {
  flex: 1;
  min-width: 0;
}

/* ===== 备注文本域 ===== */
.textarea-wrap {
  border: 2rpx solid #e8edf2;
  border-radius: 24rpx;
  padding: 18rpx 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-sizing: border-box;
}

.remark-textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #1a1a1a;
}

/* ===== 错误提示（覆盖全局 .error-inline） ===== */
.upload-page .error-inline {
  margin-top: 6rpx !important;
  color: #e14d69;
  font-size: 24rpx;
  line-height: 1.5;
}

/* ===== 提交按钮（覆盖全局 .submit-btn） ===== */
.upload-page .submit-wrap {
  padding: 20rpx 0 0;
}

.upload-page .submit-btn {
  width: 100% !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border: 0 !important;
  border-radius: 28rpx !important;
  background: linear-gradient(180deg, #c0e7ff 0%, #b0ddfa 100%) !important;
  color: #24435a;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 28rpx rgba(176, 221, 250, 0.28);
  margin-top: 0 !important;
  padding: 0 !important;
}

.upload-page .submit-btn::after {
  border: 0;
}
