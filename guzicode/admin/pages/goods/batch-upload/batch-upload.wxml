<view class="batch-shell">
  <view class="batch-page">
    <!-- 批量上传图片 -->
    <view class="form-card">
      <view class="card-label-row">
        <view class="card-label">商品图片 <text class="required">*</text></view>
        <view class="link-hint">表格图片字段需与文件名一致</view>
      </view>
      <view class="upload-action-btn" bindtap="choosePhoto">
        <view class="upload-action-icon"></view>
        <text class="upload-action-text">选择图片</text>
      </view>
      <view class="upload-success-hint">已上传 {{form.imagePaths.length}} 张图片（单张 ≤ 5M）</view>
      <view class="table-hint">可多次点击选择图片，图片会自动累积</view>
      <view class="table-hint">同一条商品可填写多个图片名称，使用英文逗号分隔，例如：1.png,2.png</view>
      <view class="table-hint">Excel 图片字段必须填写上传图片的完整文件名，例如：24.jpg</view>
      <view wx:if="{{errors.images}}" class="error-inline">{{errors.images}}</view>
    </view>

    <view class="form-card">
      <view class="card-label">寄售用户 <text class="required">*</text></view>
      <picker mode="selector" range="{{ownerPickerOptions}}" value="{{ownerIndex}}" bindchange="onOwnerChange">
        <view class="field-input picker-input">
          <text class="{{form.owner ? '' : 'is-placeholder'}}">{{form.owner || '请选择寄售用户'}}</text>
          <view class="picker-arrow-btn"></view>
        </view>
      </picker>
      <view wx:if="{{errors.owner}}" class="error-inline">{{errors.owner}}</view>
    </view>

    <!-- 上传表格文件 -->
    <view class="form-card">
      <view class="card-label-row">
        <view class="card-label">商品表格 <text class="required">*</text></view>
        <view class="link-hint">支持 .csv / .xlsx / .xls</view>
      </view>
      <view class="table-hint">先下载模板填写多条商品数据，再上传表格。图片字段必须与上传图片文件名一致，多个名称使用英文逗号分隔。当前导入支持 CSV / XLSX / XLS。</view>
      <view class="upload-action-btn" bindtap="downloadTemplate">
        <view class="upload-file-icon"></view>
        <text class="upload-action-text">下载商品模板</text>
      </view>
      <view class="upload-action-btn" bindtap="chooseFile">
        <view class="upload-file-icon"></view>
        <text class="upload-action-text">选择 Excel 表格</text>
      </view>
      <view wx:if="{{form.fileName}}" class="upload-file-info">
        <view class="file-icon-tag">表</view>
        <text class="file-name-text">{{form.fileName}}</text>
        <view class="file-delete-btn" catchtap="clearFile"></view>
      </view>
      <view wx:if="{{errors.file}}" class="error-inline">{{errors.file}}</view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-wrap">
      <button class="submit-btn" bindtap="handleSubmit">提交批量上传</button>
    </view>
  </view>
</view>
