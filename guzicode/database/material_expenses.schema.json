{
  "collectionName": "material_expenses",
  "description": "材料支出记录，存储包装耗材等支出",
  "fields": [
    {
      "name": "itemName",
      "type": "string",
      "required": true,
      "description": "材料项目名称"
    },
    {
      "name": "amount",
      "type": "number",
      "required": true,
      "description": "支出金额"
    },
    {
      "name": "date",
      "type": "string",
      "required": true,
      "description": "发生日期，格式 YYYY-MM-DD"
    },
    {
      "name": "note",
      "type": "string",
      "required": false,
      "description": "备注说明"
    },
    {
      "name": "vouchers",
      "type": "array",
      "required": false,
      "description": "凭证图片数组"
    },
    {
      "name": "createdAt",
      "type": "date",
      "required": true,
      "description": "创建时间"
    },
    {
      "name": "updatedAt",
      "type": "date",
      "required": true,
      "description": "更新时间"
    }
  ]
}
