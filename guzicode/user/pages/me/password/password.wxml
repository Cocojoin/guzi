<view class="u-page password-page">
  <view class="u-content">
    <view class="u-topbar">
      <view class="u-back" bindtap="goBack"></view>
      <view class="u-top-title">修改密码</view>
    </view>

    <view class="u-card pwd-card">
      <view class="pwd-field">
        <view class="pwd-label">原密码 <text>*</text></view>
        <view class="pwd-input {{errors.oldPassword ? 'pwd-input--error' : ''}}">
          <input password="{{!visible.oldPassword}}" value="{{form.oldPassword}}" data-field="oldPassword" bindinput="onFieldInput" />
          <view class="pwd-eye" data-field="oldPassword" bindtap="toggleVisible">
            <image
              class="pwd-eye-icon"
              src="/assets/customer-icons/{{visible.oldPassword ? 'password-show' : 'password-hide'}}.svg"
              mode="aspectFit"
            />
          </view>
        </view>
      </view>
      <view class="pwd-field">
        <view class="pwd-label">新密码 <text>*</text></view>
        <view class="pwd-input {{errors.newPassword ? 'pwd-input--error' : ''}}">
          <input password="{{!visible.newPassword}}" value="{{form.newPassword}}" data-field="newPassword" bindinput="onFieldInput" />
          <view class="pwd-eye" data-field="newPassword" bindtap="toggleVisible">
            <image
              class="pwd-eye-icon"
              src="/assets/customer-icons/{{visible.newPassword ? 'password-show' : 'password-hide'}}.svg"
              mode="aspectFit"
            />
          </view>
        </view>
        <view class="pwd-hint">6-20 位，且不能与原密码相同</view>
        <view wx:if="{{errors.newPassword}}" class="pwd-error">{{errors.newPassword}}</view>
      </view>
      <view class="pwd-field">
        <view class="pwd-label">确认新密码 <text>*</text></view>
        <view class="pwd-input {{errors.confirmPassword ? 'pwd-input--error' : ''}}">
          <input password="{{!visible.confirmPassword}}" value="{{form.confirmPassword}}" data-field="confirmPassword" bindinput="onFieldInput" />
          <view class="pwd-eye" data-field="confirmPassword" bindtap="toggleVisible">
            <image
              class="pwd-eye-icon"
              src="/assets/customer-icons/{{visible.confirmPassword ? 'password-show' : 'password-hide'}}.svg"
              mode="aspectFit"
            />
          </view>
        </view>
        <view wx:if="{{errors.confirmPassword}}" class="pwd-error">{{errors.confirmPassword}}</view>
      </view>
    </view>

    <button class="primary-btn pwd-submit" loading="{{submitting}}" disabled="{{!canSubmit || submitting}}" bindtap="submit">确认修改</button>
    <view class="safe-note">为保障账号安全，修改成功后需重新登录</view>
  </view>
</view>
