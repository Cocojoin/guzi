<view class="u-page">
  <view class="u-content">
    <view class="u-card profile-card">
      <view class="avatar">
        <text>{{avatarText}}</text>
      </view>
      <view class="profile-name">{{user.nickname}}</view>
    </view>

    <view class="u-card menu-card">
      <view class="menu-item" bindtap="goPassword">
        <view class="menu-icon">▢</view>
        <view class="menu-text">
          <view class="menu-title">修改密码</view>
          <view class="menu-desc">定期更新，账号更安全</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-line"></view>
      <view class="menu-item" bindtap="goConsignment">
        <view class="menu-icon">◇</view>
        <view class="menu-text">
          <view class="menu-title">我的寄售</view>
          <view class="menu-desc">{{consignmentDesc}}</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <view class="logout-wrap">
      <button class="logout-btn" bindtap="logout">退出登录</button>
    </view>
  </view>

</view>
