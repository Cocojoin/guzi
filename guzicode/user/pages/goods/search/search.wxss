@import "../../../user.wxss";

.search-page {
  overflow: visible;
}

.search-topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.search-input-wrap {
  flex: 1;
  height: 84rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(217, 236, 248, 0.92);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.search-icon {
  color: #8a97b0;
  font-size: 34rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
  color: #2b3d55;
}

.search-placeholder {
  color: #a5afc2;
  font-size: 28rpx;
}

.search-btn {
  flex-shrink: 0;
  color: #2b3d55;
  font-size: 30rpx;
  font-weight: 700;
  padding: 0 10rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  color: #304158;
  font-size: 28rpx;
  font-weight: 700;
}

.section-action {
  color: #e86a8e;
  font-size: 24rpx;
  font-weight: 600;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-pill {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #60708a;
  font-size: 26rpx;
  font-weight: 600;
}

.tag-pill--hot {
  background: rgba(255, 217, 229, 0.92);
  color: #d85a80;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goods-card {
  display: flex;
  gap: 20rpx;
  padding: 22rpx;
  align-items: center;
}

.goods-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex: 0 0 140rpx;
  background: linear-gradient(135deg, #eef3fb, #dde7f5);
}

.goods-img,
.goods-fallback {
  width: 100%;
  height: 100%;
}

.goods-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #92a0b6;
  font-size: 48rpx;
  font-weight: 900;
}

.goods-body {
  min-width: 0;
  flex: 1;
}

.goods-title {
  color: #2a3c54;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
}

.goods-meta {
  margin-top: 12rpx;
  color: #8b97ad;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.goods-price {
  margin-top: 12rpx;
  color: #ef4a6f;
  font-size: 36rpx;
  font-weight: 900;
}
