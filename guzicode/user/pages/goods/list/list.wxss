@import "../../../user.wxss";

page {
  background: linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.market-page {
  overflow: visible;
}

.search-shell {
  position: relative;
  z-index: 30;
  margin-bottom: 46rpx;
}

.search-bar {
  height: 88rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(255, 255, 255, 0.86);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  box-shadow: 0 14rpx 36rpx rgba(131, 150, 184, 0.14);
}

.search-icon {
  font-size: 34rpx;
  color: #9aa7bc;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #2b3d55;
}

.search-placeholder {
  color: #a2aec2;
}

.search-clear {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #edf2fa;
  color: #7d8ca3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  line-height: 1;
}

.search-panel {
  position: relative;
  z-index: 35;
}

.search-panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(244, 247, 252, 0.7);
}

.search-panel-card {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 28rpx;
}

.search-panel-header,
.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.search-panel-header {
  margin-bottom: 24rpx;
}

.search-panel-title,
.section-title {
  color: #304158;
  font-size: 28rpx;
  font-weight: 800;
}

.search-panel-action,
.section-action {
  color: #8d7ce6;
  font-size: 24rpx;
  font-weight: 700;
}

.search-section + .search-section {
  margin-top: 28rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.tag-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f4f6fb;
  color: #60708a;
  font-size: 24rpx;
  font-weight: 700;
}

.tag-pill--hot {
  background: #ffe9f0;
  color: #db6688;
}

.state-card {
  padding: 48rpx 36rpx;
  text-align: center;
}

.state-title {
  color: #2f4159;
  font-size: 30rpx;
  font-weight: 800;
}

.state-desc {
  margin-top: 14rpx;
  color: #8b97ad;
  font-size: 24rpx;
  line-height: 1.6;
}

.banner-section {
  margin-bottom: 32rpx;
}

.banner-swiper {
  height: 292rpx;
}

.banner-card {
  position: relative;
  height: 100%;
  border-radius: 36rpx;
  overflow: hidden;
  padding: 34rpx 36rpx;
  margin: 0 8rpx;
  box-sizing: border-box;
  color: #ffffff;
}

.banner-card--pink {
  background: linear-gradient(135deg, #f8cade 0%, #f8b2d0 100%);
}

.banner-card--purple {
  background: linear-gradient(135deg, #ded2ff 0%, #cdb9ff 100%);
}

.banner-card--blue {
  background: linear-gradient(135deg, #d9e8ff 0%, #bdd9ff 100%);
}

.banner-card--green {
  background: linear-gradient(135deg, #d9f0e5 0%, #b7e2cb 100%);
}

.banner-card--orange {
  background: linear-gradient(135deg, #ffe3cf 0%, #ffc8a8 100%);
}

.banner-tag {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #ec6e93;
  font-size: 22rpx;
  font-weight: 800;
}

.banner-name {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1.2;
}

.banner-meta {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
}

.banner-mark {
  position: absolute;
  right: 18rpx;
  bottom: -10rpx;
  font-size: 180rpx;
  line-height: 1;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.2);
}

.banner-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.banner-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(154, 166, 187, 0.35);
}

.banner-dot--active {
  width: 32rpx;
  border-radius: 999rpx;
  background: #8898b4;
}

.section-row--list {
  margin-bottom: 20rpx;
}

.ip-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ip-card {
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.ip-cover {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 92rpx;
  position: relative;
  overflow: hidden;
}

.ip-cover::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0));
}

.ip-cover--pink {
  background: linear-gradient(135deg, #fbe2eb, #f8c7d8);
}

.ip-cover--purple {
  background: linear-gradient(135deg, #ece4ff, #d8caf8);
}

.ip-cover--blue {
  background: linear-gradient(135deg, #e4eeff, #cadbfb);
}

.ip-cover--green {
  background: linear-gradient(135deg, #e4f4ea, #c9e7d8);
}

.ip-cover--orange {
  background: linear-gradient(135deg, #ffeddc, #ffd8bc);
}

.ip-cover-text {
  position: relative;
  z-index: 1;
  font-size: 42rpx;
  font-weight: 900;
  color: rgba(90, 102, 132, 0.72);
}

.ip-body {
  flex: 1;
  min-width: 0;
}

.ip-name {
  color: #2c3d55;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.3;
}

.ip-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.badge {
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 800;
}

.badge-sale {
  background: #ffe8ef;
  color: #db6688;
}

.badge-role {
  background: #e9eef9;
  color: #6882b0;
}

.ip-arrow {
  color: #b7c2d4;
  font-size: 42rpx;
  line-height: 1;
  padding-right: 8rpx;
}
