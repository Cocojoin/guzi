@import "../../../user.wxss";

.goods-list-page {
  box-sizing: border-box;
  overflow: visible;
  position: relative;
}

.banner-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  z-index: 0;
}

.u-content {
  position: relative;
  z-index: 1;
}

.search-section {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 10;
}

.search-shell {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #000000;
  line-height: 1;
  flex-shrink: 0;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 36rpx;
  padding: 6rpx 20rpx;
  box-shadow: none;
  border: 1rpx solid rgba(200, 210, 225, 0.4);
}

.search-icon {
  width: 34rpx;
  height: 34rpx;
  font-size: 28rpx;
  color: #94a0b0;
  margin-right: 10rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #334050;
  background: transparent;
  line-height: 36rpx;
}

.search-placeholder {
  color: #a0aab8;
}

.search-clear,
.search-btn {
  color: #6f7f99;
  font-size: 28rpx;
  font-weight: 800;
  position: relative;
  z-index: 10;
}

.search-clear {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
}

.search-btn {
  height: 72rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  line-height: 1;
  color: #293a50;
  font-weight: 800;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 20rpx;
}

.filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 36rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.85);
  color: #5a6a7e;
  font-size: 28rpx;
  font-weight: 600;
  border: 1rpx solid rgba(180, 200, 225, 0.5);
  box-shadow: none;
}

.filter-chip--active {
  background: #ffffff;
  border: 1rpx solid rgba(160, 190, 230, 0.8);
  box-shadow: none;
}

.filter-chip-text {
  font-weight: 600;
  color: #293a50;
}

.filter-chip-arrow {
  font-size: 14rpx;
  color: #293a50;
  line-height: 1;
  margin-left: 4rpx;
}

.dropdown-panel {
  position: absolute;
  top: 200rpx;
  left: 0;
  right: 0;
  z-index: 60;
}

.dropdown-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  z-index: 59;
}

.dropdown-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 48rpx rgba(100, 120, 160, 0.18);
  padding: 16rpx 0;
  max-height: 440rpx;
  overflow-y: auto;
}

.dropdown-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  color: #48576e;
}

.dropdown-option--active {
  color: #293a50;
  font-weight: 700;
}

.dropdown-check {
  color: #377ba9;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
}

.search-info {
  margin-bottom: 20rpx;
}

.history-section,
.hot-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #48576e;
}

.clear-history {
  font-size: 24rpx;
  color: #a0aebf;
}

.history-tags,
.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.65);
  color: #60708a;
  font-size: 26rpx;
  font-weight: 600;
}

.tag-pill--hot {
  background: rgba(247, 182, 207, 0.15);
  color: #c34e6c;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.badge-up {
  color: #5a9fc8;
  background: rgba(180, 220, 255, 0.45);
  align-self: flex-start;
}
