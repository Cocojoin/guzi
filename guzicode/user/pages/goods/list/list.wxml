<view class="u-page u-page--tabbar market-page">
  <view class="u-content">
    <view class="search-shell" catchtap="goSearch">
      <view class="search-bar">
        <text class="search-icon">⌕</text>
        <text class="search-placeholder">搜索 IP / 角色 / 系列名</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="state-card u-card">
      <view class="state-title">正在加载 IP 分类…</view>
    </view>

    <block wx:elif="{{!ipSummaries.length}}">
      <view class="state-card u-card">
        <view class="state-title">暂无可浏览 IP</view>
        <view class="state-desc">当前没有上架商品，晚点再来看看吧</view>
      </view>
    </block>

    <block wx:else>
      <view wx:if="{{bannerItems.length}}" class="banner-section">
        <swiper
          class="banner-swiper"
          indicator-dots="{{false}}"
          autoplay="{{false}}"
          circular="{{bannerItems.length > 1}}"
          current="{{bannerCurrent}}"
          bindchange="onBannerChange"
        >
          <swiper-item wx:for="{{bannerItems}}" wx:key="ip">
            <view class="banner-card banner-card--{{item.tone}}" data-ip="{{item.ip}}" bindtap="openIp">
              <view class="banner-tag">{{item.bannerTag}}</view>
              <view class="banner-name">{{item.ip}}</view>
              <view class="banner-meta">{{item.saleCount}} 件在售 · {{item.roleCount}} 个角色</view>
              <view class="banner-mark">{{item.initials}}</view>
            </view>
          </swiper-item>
        </swiper>

        <view wx:if="{{bannerItems.length > 1}}" class="banner-dots">
          <view
            wx:for="{{bannerItems}}"
            wx:key="ip"
            class="banner-dot {{bannerCurrent === index ? 'banner-dot--active' : ''}}"
          ></view>
        </view>
      </view>

      <view class="ip-section">
        <view class="section-row section-row--list">
          <text class="section-title">全部 IP</text>
        </view>

        <view class="ip-list">
          <view class="ip-card u-card" wx:for="{{ipSummaries}}" wx:key="ip" data-ip="{{item.ip}}" bindtap="openIp">
            <view class="ip-cover ip-cover--{{item.tone}}">
              <text class="ip-cover-text">{{item.initials}}</text>
            </view>
            <view class="ip-body">
              <view class="ip-name">{{item.ip}}</view>
              <view class="ip-badges">
                <text class="badge badge-sale">{{item.saleCount}} 件在售</text>
                <text class="badge badge-role">{{item.roleCount}} 个角色</text>
              </view>
            </view>
            <view class="ip-arrow">›</view>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
