@import "../../../user.wxss";

.u-topbar {
  align-items: center;
  padding-right: env(safe-area-inset-right);
  gap: 16rpx;
}

.title-wrap {
  min-width: 0;
  flex: 1;
}

.consignment-home-page {
  padding-top: 30rpx;
  box-sizing: border-box;
}

.rate-card {
  min-height: 214rpx;
  border-radius: 34rpx;
  padding: 34rpx 42rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 92% 10%, rgba(255, 255, 255, 0.22), transparent 28%),
    linear-gradient(145deg, #bde4ff, #94c3f5);
  color: #2a3d56;
  margin-bottom: 34rpx;
}

.rate-label,
.rate-desc {
  font-size: 28rpx;
  font-weight: 800;
  color: #50657e;
  line-height: 1.5;
}

.rate-value {
  margin-top: 12rpx;
  font-size: 74rpx;
  font-weight: 900;
  line-height: 1.05;
}

.rate-desc {
  margin-top: 10rpx;
}

.manage-row {
  min-height: 132rpx;
  padding: 28rpx 34rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.manage-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, #ffe1ec, #dff1ff);
  color: #7975d6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.manage-text {
  flex: 1;
}

.manage-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #26384f;
}

.manage-desc {
  margin-top: 8rpx;
  color: #8b98ad;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
}

.manage-count {
  color: #26384f;
  font-size: 36rpx;
  font-weight: 900;
}

.manage-arrow {
  color: #a3adbd;
  font-size: 42rpx;
}

.intro-card {
  margin-top: 26rpx;
  padding: 18rpx 38rpx;
}

.intro-hero {
  min-height: 270rpx;
  border-radius: 34rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  background: linear-gradient(145deg, rgba(255,255,255,0.35), rgba(195, 230, 255, 0.28));
  padding: 34rpx 44rpx;
  box-sizing: border-box;
}

.hero-icon {
  width: 118rpx;
  height: 118rpx;
  margin: 0 auto 22rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
}

.hero-title {
  text-align: center;
  color: #26384f;
  font-size: 36rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 14rpx;
  text-align: center;
  color: #66758e;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.6;
}

.step-row {
  min-height: 118rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.step-no {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffd6e6, #dff1ff);
  color: #8f8fe4;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-body {
  flex: 1;
}

.step-line {
  height: 2rpx;
  margin-left: 68rpx;
  background: rgba(210, 219, 234, 0.66);
}

.note-item {
  margin-top: 14rpx;
  color: #66758e;
  font-size: 28rpx;
  line-height: 1.7;
  font-weight: 600;
}

.note-card {
  margin-top: 26rpx;
  padding: 30rpx 34rpx;
}

.contact-card {
  margin-top: 26rpx;
  padding: 26rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.contact-icon {
  width: 82rpx;
  height: 82rpx;
  flex: 0 0 82rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.contact-info {
  flex: 1;
  min-width: 0;
}

.contact-title {
  color: #26384f;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 900;
}

.contact-text {
  margin-top: 4rpx;
  color: #66758e;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 600;
}

.contact-btn {
  margin: 0;
  width: 176rpx;
  min-width: 176rpx;
  padding: 0;
  height: 68rpx;
  line-height: 68rpx;
  flex: 0 0 176rpx;
  border-radius: 999rpx;
  border: 0;
  background: linear-gradient(90deg, #f7c0d5, #b5dcff);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.contact-btn::after {
  border: 0;
}
