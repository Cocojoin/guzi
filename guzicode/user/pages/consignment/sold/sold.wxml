<view class="u-page u-page--compact">
  <view class="u-content">
    <view wx:if="{{loading && !hasLoaded}}" class="empty-note">加载中…</view>
    <view wx:elif="{{products.length === 0}}" class="u-card empty-card empty-card--search">
      <view class="empty-emoji">🧾</view>
      <view class="empty-title">暂无已出售商品</view>
      <view class="empty-desc">商品售出后会出现在这里</view>
    </view>

    <block wx:else>
      <view class="u-card sold-card" wx:for="{{products}}" wx:key="id">
        <view class="sold-head">
          <view class="goods-thumb small-thumb">
            <image wx:if="{{item.coverImage}}" class="goods-img" src="{{item.coverImage}}" mode="aspectFit" />
          </view>
          <view class="sold-info">
            <view class="goods-title single-line">{{item.title}}</view>
            <view class="goods-meta">#{{item.id}} · {{item.ip}}</view>
          </view>
          <view class="badge status-pill--sold">已售出</view>
        </view>
        <view class="sold-line"><text>出售价格</text><text class="sold-price">{{item.priceText}}</text></view>
        <view class="sold-line"><text>出售时间</text><text>{{item.soldTimeText}}</text></view>
        <view class="sold-line"><text>订单编号</text><text>{{item.orderNo}}</text></view>
      </view>
      <view wx:if="{{loading && hasLoaded}}" class="list-refresh-tip">刷新中…</view>
    </block>
  </view>
</view>
