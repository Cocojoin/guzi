<view class="u-page u-page--compact">
  <view class="u-content">
    <view wx:if="{{loading && !hasLoaded}}" class="empty-note">加载中…</view>
    <view wx:elif="{{soldItems.length === 0}}" class="u-card empty-card empty-card--search">
      <view class="empty-emoji">🧾</view>
      <view class="empty-title">暂无已出售商品</view>
      <view class="empty-desc">商品售出后会出现在这里</view>
    </view>

    <block wx:else>
      <view class="sold-record-card u-card" wx:for="{{soldItems}}" wx:key="rowKey">
        <view class="sold-thumb">
          <image wx:if="{{item.coverImage}}" class="goods-img" src="{{item.coverImage}}" mode="aspectFill" />
          <view wx:else class="sold-thumb-star"></view>
          <view class="quality-badge {{item.qualityClassName === 'quality-badge--flaw' ? 'quality-badge--flaw' : 'quality-badge--clean'}}">{{item.qualityLabel}}</view>
        </view>
        <view class="sold-record-main">
          <view class="sold-record-title">{{item.role}} · {{item.productSeries}}</view>
          <view class="sold-record-ip">{{item.ip}}</view>
          <view class="sold-record-sale">¥{{item.totalPriceText}} · 售 {{item.soldQty}} 件</view>
          <view class="sold-record-time">{{item.soldTimeText}}</view>
        </view>
      </view>
      <view wx:if="{{loading && hasLoaded}}" class="list-refresh-tip">刷新中…</view>
    </block>
  </view>
</view>
