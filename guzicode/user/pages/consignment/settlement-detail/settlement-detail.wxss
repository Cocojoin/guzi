@import "../../../user.wxss";

.u-topbar {
  align-items: center;
  padding-right: env(safe-area-inset-right);
  gap: 16rpx;
}

.title-wrap {
  min-width: 0;
  flex: 1;
}

.settle-hero {
  padding: 34rpx 38rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 90% 8%, rgba(255, 255, 255, 0.24), transparent 28%),
    linear-gradient(145deg, #c9f0e6, #cbe9ff);
  color: #2a3d56;
  margin-bottom: 36rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.settle-big {
  margin-top: 12rpx;
  font-size: 66rpx;
  font-weight: 900;
}

.settle-grid {
  display: flex;
  gap: 30rpx;
  margin-top: 20rpx;
}

.settle-grid view {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.settle-grid text:first-child {
  color: #72849a;
}

.section-title {
  color: #34465f;
  font-size: 28rpx;
  font-weight: 900;
  margin: 26rpx 0 18rpx;
}

.detail-product {
  padding: 26rpx;
  display: flex;
  gap: 22rpx;
  margin-bottom: 26rpx;
}

.small-thumb {
  width: 104rpx;
  height: 104rpx;
  flex-basis: 104rpx;
}

.settle-product-body {
  flex: 1;
  min-width: 0;
}

.money-cols {
  display: flex;
  gap: 28rpx;
  margin-top: 16rpx;
}

.money-cols view {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  color: #7d8ba0;
  font-size: 24rpx;
  font-weight: 800;
}

.money-cols text:last-child {
  color: #293a50;
  font-size: 28rpx;
}

.money-cols .fee {
  color: #f05e83;
}

.money-cols .net {
  color: #48a18e;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 18rpx;
}

.photo-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f0f4f9;
}

.photo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.empty-card {
  padding: 60rpx 26rpx;
  text-align: center;
}
