<view class="u-page">
  <view class="u-content">
    <view class="u-topbar">
      <view class="u-back" bindtap="goBack"></view>
      <view class="title-wrap">
        <view class="u-top-title">寄售商品</view>
      </view>
    </view>

    <view class="search-row">
      <view class="u-search search-box">
        <text class="u-search-icon">⌕</text>
        <input class="u-search-input" placeholder="搜索我的寄售商品" placeholder-class="u-placeholder" value="{{keyword}}" bindinput="onSearchInput" />
      </view>
      <view class="u-icon-btn add-btn" bindtap="goAdd">+</view>
    </view>

    <view class="filter-panel">
      <view class="filter-row">
        <view class="filter-dropdown {{activeDropdown === 'role' ? 'filter-dropdown--active' : ''}}" bindtap="toggleDropdown" data-key="role">
          <text class="filter-dropdown-text">{{roleOptions[roleIndex]}}</text>
          <text class="filter-arrow {{activeDropdown === 'role' ? 'filter-arrow--up' : ''}}">▼</text>
        </view>
        <view class="filter-dropdown {{activeDropdown === 'ip' ? 'filter-dropdown--active' : ''}}" bindtap="toggleDropdown" data-key="ip">
          <text class="filter-dropdown-text">{{ipOptions[ipIndex]}}</text>
          <text class="filter-arrow {{activeDropdown === 'ip' ? 'filter-arrow--up' : ''}}">▼</text>
        </view>
        <view class="filter-dropdown {{activeDropdown === 'status' ? 'filter-dropdown--active' : ''}}" bindtap="toggleDropdown" data-key="status">
          <text class="filter-dropdown-text">{{statusOptions[statusIndex]}}</text>
          <text class="filter-arrow {{activeDropdown === 'status' ? 'filter-arrow--up' : ''}}">▼</text>
        </view>
      </view>

      <view wx:if="{{activeDropdown === 'role'}}" class="dropdown-panel">
        <view class="dropdown-panel-mask" bindtap="closeDropdown"></view>
        <view class="dropdown-panel-content">
          <view class="dropdown-option {{roleIndex === index ? 'dropdown-option--active' : ''}}" wx:for="{{roleOptions}}" wx:key="index" data-key="role" data-index="{{index}}" bindtap="onDropdownSelect">
            <text>{{item}}</text>
            <text wx:if="{{roleIndex === index}}" class="dropdown-check">✓</text>
          </view>
        </view>
      </view>

      <view wx:if="{{activeDropdown === 'ip'}}" class="dropdown-panel">
        <view class="dropdown-panel-mask" bindtap="closeDropdown"></view>
        <view class="dropdown-panel-content">
          <view class="dropdown-option {{ipIndex === index ? 'dropdown-option--active' : ''}}" wx:for="{{ipOptions}}" wx:key="index" data-key="ip" data-index="{{index}}" bindtap="onDropdownSelect">
            <text>{{item}}</text>
            <text wx:if="{{ipIndex === index}}" class="dropdown-check">✓</text>
          </view>
        </view>
      </view>

      <view wx:if="{{activeDropdown === 'status'}}" class="dropdown-panel">
        <view class="dropdown-panel-mask" bindtap="closeDropdown"></view>
        <view class="dropdown-panel-content">
          <view class="dropdown-option {{statusIndex === index ? 'dropdown-option--active' : ''}}" wx:for="{{statusOptions}}" wx:key="index" data-key="status" data-index="{{index}}" bindtap="onDropdownSelect">
            <text>{{item}}</text>
            <text wx:if="{{statusIndex === index}}" class="dropdown-check">✓</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{loading && !hasLoaded}}" class="empty-note">加载中…</view>
    <view wx:elif="{{products.length === 0}}" class="u-card empty-card empty-card--consignment">
      <view class="empty-emoji">📦</view>
      <view class="empty-title">暂无寄售商品</view>
      <view class="empty-desc">点击下方按钮，上传你的第一件寄售好物</view>
      <button class="primary-btn" bindtap="goAdd">添加商品</button>
    </view>

    <block wx:else>
      <view class="u-card goods-card" wx:for="{{products}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
        <view class="goods-thumb">
          <image wx:if="{{item.picture}}" class="goods-img" src="{{item.picture}}" mode="aspectFill" />
        </view>
        <view class="goods-body">
          <view class="goods-title">{{item.title}}</view>
          <view class="goods-meta">数量 {{item.remainingCount}} · {{item.ip}}</view>
          <view class="goods-price">{{item.priceText}}</view>
        </view>
        <view class="goods-side">
          <view class="badge {{item.qualityClassName === 'quality-badge--flaw' ? 'badge-flaw' : 'badge-clean'}} goods-quality-badge">{{item.qualityLabel}}</view>
          <view class="badge {{item.statusClassName}}">{{item.statusLabel}}</view>
        </view>
      </view>
      <view class="end-line">—— 没有更多了 ——</view>
      <view wx:if="{{loading && hasLoaded}}" class="list-refresh-tip">刷新中…</view>
    </block>
  </view>
</view>
