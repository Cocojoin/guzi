@import "../../../user.wxss";

.u-page {
  overflow: visible;
}

.u-topbar {
  align-items: center;
  padding-right: env(safe-area-inset-right);
  gap: 16rpx;
}

.title-wrap {
  min-width: 0;
  flex: 1;
}

.add-btn {
  font-size: 40rpx;
  flex: 0 0 66rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-box {
  flex: 1;
  margin: 0;
}

.filter-panel {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 40;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-dropdown {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 10rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.75);
  color: #60708a;
  font-size: 24rpx;
  font-weight: 600;
  flex: 1;
}

.filter-dropdown--active {
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 6rpx 20rpx rgba(104, 130, 158, 0.16);
}

.filter-arrow {
  font-size: 16rpx;
  line-height: 1;
  margin-top: -2rpx;
  transition: transform 0.2s;
}

.filter-arrow--up {
  transform: rotate(180deg);
}

.dropdown-panel {
  position: absolute;
  top: 76rpx;
  left: 0;
  right: 0;
  z-index: 60;
}

.dropdown-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
}

.dropdown-panel-content {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 40rpx rgba(104, 130, 158, 0.28);
  padding: 12rpx 0;
  max-height: 440rpx;
  overflow-y: auto;
}

.dropdown-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: #48576e;
}

.dropdown-option--active {
  color: #293a50;
  font-weight: 700;
}

.dropdown-check {
  color: #377ba9;
  font-size: 32rpx;
  line-height: 1;
}

.goods-thumb {
  width: 132rpx;
  height: 132rpx;
  flex: 0 0 132rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
}

.goods-card {
  align-items: center;
}

.goods-side {
  min-width: 140rpx;
  gap: 12rpx;
  flex-shrink: 0;
}

.goods-quality-badge {
  margin-top: 0;
}

.goods-side .badge {
  min-width: 100%;
  padding: 0 12rpx;
  justify-content: center;
  box-sizing: border-box;
  text-align: center;
}

.empty-card--consignment {
  margin-top: 120rpx;
  background: transparent;
  border-color: transparent;
  box-shadow: none;
}
