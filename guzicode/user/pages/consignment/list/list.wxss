@import "../../../user.wxss";

page {
  background: linear-gradient(180deg, #fcfeff 0%, #eef8ff 100%);
}

.consignment-page {
  overflow: visible;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.u-page {
  padding-top: calc(env(safe-area-inset-top) + 30rpx);
  position: relative;
}

.u-content {
  position: relative;
  z-index: 1;
}

.search-section {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 10;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 18rpx 18rpx 18rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(120, 140, 180, 0.08);
}

.search-icon {
  font-size: 32rpx;
  color: #8fa0b8;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #293a50;
  background: transparent;
}

.search-placeholder {
  color: #a8b6cb;
}

.search-icon-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f5ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.magnifier {
  font-size: 36rpx;
  color: #293a50;
  font-weight: 600;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #48576e;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid rgba(200, 210, 230, 0.6);
  flex: 1;
  box-shadow: 0 4rpx 16rpx rgba(120, 140, 180, 0.06);
}

.filter-chip--active {
  background: #ffffff;
  border: 2rpx solid #7ba5d6;
  box-shadow: 0 6rpx 20rpx rgba(123, 165, 214, 0.18);
}

.filter-chip-text {
  font-weight: 600;
  color: #293a50;
}

.filter-chip-arrow {
  font-size: 14rpx;
  color: #293a50;
  line-height: 1;
  margin-left: 4rpx;
}

.dropdown-panel {
  position: absolute;
  top: 200rpx;
  left: 0;
  right: 0;
  z-index: 200;
}

.dropdown-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  z-index: 0;
}

.dropdown-card {
  position: relative;
  z-index: 2;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 48rpx rgba(100, 120, 160, 0.18);
  padding: 16rpx 0;
  max-height: 440rpx;
  overflow-y: auto;
}

.dropdown-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  color: #48576e;
}

.dropdown-option--active {
  color: #293a50;
  font-weight: 700;
}

.dropdown-check {
  color: #377ba9;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
}

.goods-card {
  position: relative;
  padding: 28rpx;
  align-items: flex-start;
  gap: 26rpx;
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 18rpx 42rpx rgba(116, 148, 181, 0.12);
}

.list-goods-thumb {
  position: relative;
  width: 144rpx;
  height: 172rpx;
  flex: 0 0 144rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fde3ef 0%, #d4e5ff 100%);
}

.goods-thumb-star {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 34rpx;
  height: 34rpx;
  transform: translate(-50%, -50%) rotate(45deg);
  background: rgba(255, 255, 255, 0.96);
  border-radius: 8rpx;
}

.quality-chip {
  position: absolute;
  left: 10rpx;
  top: 10rpx;
  min-width: 54rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

.quality-chip--flaw {
  background: #d95078;
}

.quality-chip--clean {
  background: #35a978;
}

.goods-body {
  min-width: 0;
  flex: 1;
}

.goods-title-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.goods-title {
  flex: 1;
  min-width: 0;
  color: #33425f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-chip {
  flex-shrink: 0;
  min-width: 88rpx;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
  box-sizing: border-box;
}

.goods-ip {
  margin-top: 14rpx;
  color: #5c6680;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price {
  margin-top: 12rpx;
  color: #f05e83;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.goods-count-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.sold-count {
  color: #d95078;
}

.remain-count {
  color: #31577f;
}

.progress-track {
  position: relative;
  height: 10rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #75bee5;
}

.progress-sold {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  border-radius: 999rpx 0 0 999rpx;
  background: #f06a86;
}

.progress-sold[style*="100%"] {
  border-radius: 999rpx;
}

.status-pill--up {
  color: #377ba9;
  background: #dcefff;
}

.status-pill--down {
  color: #7d8ba0;
  background: #edf2f8;
}

.status-pill--sold {
  color: #d85070;
  background: #ffe5ee;
}

.status-pill--settled {
  color: #349a76;
  background: #d8f5e9;
}

.list-goods-thumb .goods-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.goods-card .badge {
  justify-content: center;
  box-sizing: border-box;
  text-align: center;
}

.float-add-btn {
  position: fixed;
  right: 44rpx;
  bottom: calc(env(safe-area-inset-bottom) + 60rpx);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffb8d1 0%, #a8d5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(180, 160, 220, 0.4);
  z-index: 100;
}

.float-add-btn text {
  font-size: 64rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
  margin-top: -6rpx;
}

.empty-card--consignment {
  margin-top: 160rpx;
  background: transparent;
  border-color: transparent;
  box-shadow: none;
}
